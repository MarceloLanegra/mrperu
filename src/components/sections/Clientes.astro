---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const modules = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/clients/*.webp",
  { eager: true }
);

const clients = Object.entries(modules)
  .map(([path, mod]) => {
    const file = path.split("/").pop() || "logo";
    const alt = file.replace(".webp", "").replace(/[-_]/g, " ");
    return { src: mod.default, alt };
  })
  .sort((a, b) => a.alt.localeCompare(b.alt));

// duplicamos para loop infinito sin cortes
const track = [...clients, ...clients];
---

<section id="clientes" class="w-full bg-[#0197C5]">
  <div class="mx-auto w-[min(1200px,calc(100%-24px))] py-3">
    <div class="flex items-center gap-4">
      <div class="shrink-0">
        <span class="inline-flex items-center rounded-2xl border border-white/70 px-4 py-2 text-sm font-semibold text-white">
          Principales Clientes
        </span>
      </div>

      <div class="relative flex-1 overflow-hidden">
        <div class="clients-track">
          {track.map((c) => (
            <div class="client-item">
              <Image src={c.src} alt={c.alt} class="h-full w-auto object-contain opacity-95" loading="lazy" decoding="async" />
            </div>
          ))}
        </div>

        <!-- fades laterales -->
        <div class="pointer-events-none absolute inset-y-0 left-0 w-10 bg-gradient-to-r from-[#0197C5] to-transparent"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 w-10 bg-gradient-to-l from-[#0197C5] to-transparent"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .clients-track{
    display:flex;
    align-items:center;
    gap:40px;
    width:max-content;
    animation: scroll 22s linear infinite;
  }

  .client-item{
    height: 36px;           /* ajusta tamaño */
    display:flex;
    align-items:center;
    flex: 0 0 auto;
  }

  /* pausa al hover */
  #clientes:hover .clients-track{
    animation-play-state: paused;
  }

  @keyframes scroll{
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 640px){
    .clients-track{ gap: 28px; animation-duration: 18s; }
    .client-item{ height: 28px; }
  }
</style>