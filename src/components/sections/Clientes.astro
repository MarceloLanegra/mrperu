---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const modules = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/clients/*.webp",
  { eager: true }
);

const clients = Object.entries(modules)
  .map(([path, mod]) => {
    const file = path.split("/").pop() || "logo";
    const alt = file.replace(".webp", "").replace(/[-_]/g, " ");
    return { src: mod.default, alt };
  })
  .sort((a, b) => a.alt.localeCompare(b.alt));

// duplicamos para loop infinito sin cortes
const track = [...clients, ...clients];
---

<section id="clientes" class="w-full bg-blue-mrperu py-2 sm:py-0 scroll-mt-24">
  <div class="mx-auto w-[min(1200px,calc(100%-20px))] py-3 sm:w-[min(1200px,calc(100%-24px))] sm:py-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
      <div class="shrink-0 text-center">
        <span class="inline-flex items-center rounded-2xl border border-white/70 px-3 py-1.5 text-xs font-semibold text-white sm:px-4 sm:py-2 sm:text-sm">
          Principales Clientes
        </span>
      </div>

      <div class="relative w-full flex-1 overflow-hidden">
        <div class="clients-track">
          {track.map((c) => (
            <div class="client-item">
              <Image src={c.src} alt={c.alt} class="h-full w-auto object-contain opacity-95" loading="lazy" decoding="async" />
            </div>
          ))}
        </div>

        <!-- fades laterales -->
        <div class="pointer-events-none absolute inset-y-0 left-0 w-10 bg-gradient-to-r from-blue-mrperu to-transparent"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 w-10 bg-gradient-to-l from-blue-mrperu to-transparent"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .clients-track{
    display:flex;
    align-items:center;
    gap:32px;
    width:max-content;
    animation: scroll 22s linear infinite;
  }

  .client-item{
    height: 60px;
    display:flex;
    align-items:center;
    flex: 0 0 auto;
  }

  /* pausa al hover */
  #clientes:hover .clients-track{
    animation-play-state: paused;
  }

  @keyframes scroll{
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (min-width: 640px){
    .clients-track{ gap: 36px; }
    .client-item{ height: 68px; }
  }

  @media (min-width: 1024px){
    .clients-track{ gap: 40px; }
    .client-item{ height: 72px; }
  }

  @media (max-width: 639px){
    .clients-track{ animation-duration: 18s; }
  }
</style>