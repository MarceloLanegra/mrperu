---
import { Image } from "astro:assets";
import imgDesktop from "../../assets/banner-elegirnos.webp";
import imgMobile from "../../assets/img-porque-xs.webp";
---

<section id="informacion" class="bg-white py-8 sm:py-12 lg:py-14">
  <div class="mx-auto w-[min(1200px,calc(100%-16px))] sm:w-[min(1200px,calc(100%-24px))]">
    <div class="overflow-hidden rounded-[18px] sm:rounded-[24px]">
      <Image
        src={imgDesktop}
        alt="¿Por qué elegirnos?"
        class="hidden h-auto w-full sm:block"
        loading="lazy"
        decoding="async"
      />

      <Image
        src={imgMobile}
        alt="¿Por qué elegirnos?"
        class="block h-auto w-full sm:hidden"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>