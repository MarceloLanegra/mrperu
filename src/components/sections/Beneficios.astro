---
import Image from "astro/components/Image.astro";
import Wrapper from "../Wrapper.astro";
import beneficiosDesktop from "../../assets/beneficio-brochure.jpg";
import beneficiosMobile from "../../assets/img-beneficios-xs.webp";

const title = "BENEFICIOS EXCLUSIVOS DEL COMPRESOR VSDS";
---

<section id="beneficios" class="bg-white py-8 sm:py-12 lg:py-14 scroll-mt-24">
  <Wrapper>
    <div class="relative mb-10 sm:mb-14 lg:mb-16">
      <div class="h-px w-full bg-slate-200"></div>
      <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] sm:w-auto sm:min-w-[520px] lg:min-w-[720px] -translate-x-1/2 -translate-y-1/2 mb-2">
        <div class="rounded-[12px] bg-white px-4 py-2 sm:px-8 shadow-[0_10px_25px_rgba(0,0,0,0.18)] ring-1 ring-black/5 sm:rounded-[14px]">
          <span class="text-blue-mrperu text-center block text-balance font-extrabold tracking-wide text-[16px] leading-tight sm:text-[18px] lg:text-[26px]">
            {title}
          </span>
        </div>
      </div>
    </div>
    <picture class="block overflow-hidden mt-3 sm:mt-4 lg:mt-5">
      <source srcset={beneficiosDesktop.src} media="(min-width: 640px)" />
      <Image
        src={beneficiosMobile}
        alt="Beneficios del compresor con sus principales componentes y ventajas"
        class="block h-auto w-full"
        loading="lazy"
        decoding="async"
      />
    </picture>
  </Wrapper>
</section>
