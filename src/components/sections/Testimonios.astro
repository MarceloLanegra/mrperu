---
import exandalImg from '../../assets/testimonios/img-exandal.webp';
import ssamyImg from '../../assets/testimonios/img-ssamy.webp';
import cosechaImg from '../../assets/testimonios/img-cosecha-andina.webp';

const cards = [
  {
    id: 1,
    name: "Gabriel Vila",
    role: "Cosecha Andina",
    text: "Los compresores Atlas Copco nos brindan aire comprimido constante, gran eficiencia energética y un funcionamiento silencioso. Han mejorado significativamente nuestras operaciones.",
    image: cosechaImg.src,
  },
  {
    id: 2,
    name: "César Esteban",
    role: "Exandal",
    text: "Los compresores VSDs nos brindan eficiencia, confiabilidad y monitoreo remoto que nos permite anticipar mantenimientos y evitar paradas operativas.",
    image: exandalImg.src,
  },
  {
    id: 3,
    name: "Rubén García",
    role: "Corporación Agrosur Ssamy",
    text: "Comenzamos con un compresor VSD+ de 20 HP y al comprobar el ahorro energético que nos brindaba, decidimos incorporar un segundo equipo VSD+ de 30 HP para una nueva línea de producción. Desde entonces, ha sido una excelente decisión para optimizar el funcionamiento de nuestras máquinas selectoras de grano.",
    image: ssamyImg.src,
    featured: true,
  },
];

const title = "EMPRESAS QUE CONFÍAN EN NOSOTROS";
---

<section id="testimonios" class="testimonios-reveal-section py-8 sm:py-12 lg:py-14">
  <div class="mx-auto w-[min(1400px,calc(100%-16px))] sm:w-[min(1400px,calc(100%-24px))]">
    <div class="testimonios-reveal testimonios-reveal-pill relative mb-16 sm:mb-14 lg:mb-16">
      <div class="h-px w-full bg-slate-200"></div>
      <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] sm:w-auto sm:min-w-[520px] lg:min-w-[620px] -translate-x-1/2 -translate-y-1/2 mb-2">
        <div class="rounded-[12px] bg-white px-4 py-3 sm:px-8 sm:py-2 shadow-[0_10px_25px_rgba(0,0,0,0.18)] ring-1 ring-black/5 sm:rounded-[14px]">
          <span class="text-blue-mrperu block text-center text-balance font-extrabold tracking-wide text-[23px] leading-[1.2] sm:leading-tight sm:text-[18px] lg:text-[26px]">
            {title}
          </span>
        </div>
      </div>
    </div>

    <div class="testimonios-reveal testimonios-reveal-stage relative overflow-hidden py-10 sm:py-12 lg:py-14 mt-4 sm:mt-5 lg:mt-6">
      <div class="testimonios-stage-wrap">
        <button class="testimonios-arrow bg-yellow-mrperu testimonios-arrow-left" type="button" aria-label="Anterior">
          <span aria-hidden="true">‹</span>
        </button>

        <div class="testimonios-stage">
          {cards.map((card, index) => {
            return (
              <article
                class:list={["testimonial-card", index === 2 && "card-center", card.featured && "is-featured"]}
                data-testimonial-index={index}
              >
                <div class="testimonial-image-wrap">
                  <img
                    src={card.image}
                    alt={`${card.name}, ${card.role}`}
                    class="testimonial-image"
                    loading="lazy"
                    decoding="async"
                  />
                </div>

                <div class="testimonial-info">
                  <div class="testimonial-meta">
                    <h3>{card.name}</h3>
                    <span class="testimonial-role">{card.role}</span>
                  </div>
                  <p class="testimonial-text">“{card.text}”</p>
                </div>
              </article>
            );
          })}
        </div>

        <button class="testimonios-arrow bg-yellow-mrperu text-white testimonios-arrow-right" type="button" aria-label="Siguiente">
          <span aria-hidden="true">›</span>
        </button>
      </div>

      <div class="testimonios-dots" aria-label="Indicadores del carrusel">
        {cards.map((_, index) => (
          <button
            type="button"
            class="testimonios-dot"
            data-dot-index={index}
            aria-label={`Ir al testimonio ${index + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const stages = document.querySelectorAll('.testimonios-stage');

  stages.forEach((stage) => {
    const cards = Array.from(stage.querySelectorAll('[data-testimonial-index]'));
    const wrap = stage.closest('.testimonios-stage-wrap');
    const prevBtn = wrap?.querySelector('.testimonios-arrow-left');
    const nextBtn = wrap?.querySelector('.testimonios-arrow-right');
    const dots = Array.from(wrap?.parentElement?.querySelectorAll('.testimonios-dot') || []);

    if (!cards.length) return;

    let activeIndex = 2;
    const total = cards.length;
    let interval;

    const applyPositions = () => {
      cards.forEach((card, index) => {
        card.classList.remove('card-left-2', 'card-left-1', 'card-center', 'card-right-1', 'card-right-2');

        const offset = (index - activeIndex + total) % total;
        const normalizedOffset = offset > Math.floor(total / 2) ? offset - total : offset;

        let positionClass = 'card-right-2';

        if (normalizedOffset <= -2) positionClass = 'card-left-2';
        else if (normalizedOffset === -1) positionClass = 'card-left-1';
        else if (normalizedOffset === 0) positionClass = 'card-center';
        else if (normalizedOffset === 1) positionClass = 'card-right-1';
        else if (normalizedOffset >= 2) positionClass = 'card-right-2';

        card.classList.add(positionClass);
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === activeIndex);
      });
    };

    const stopAuto = () => {
      window.clearInterval(interval);
    };

    const startAuto = () => {
      stopAuto();
      interval = window.setInterval(() => {
        activeIndex = (activeIndex + 1) % total;
        applyPositions();
      }, 2800);
    };

    const goTo = (index) => {
      activeIndex = index;
      applyPositions();
      startAuto();
    };

    const goToNext = () => {
      activeIndex = (activeIndex + 1) % total;
      applyPositions();
      startAuto();
    };

    const goToPrev = () => {
      activeIndex = (activeIndex - 1 + total) % total;
      applyPositions();
      startAuto();
    };

    prevBtn?.addEventListener('click', goToPrev);
    nextBtn?.addEventListener('click', goToNext);

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goTo(index));
    });

    stage.addEventListener('mouseenter', stopAuto);
    stage.addEventListener('mouseleave', startAuto);

    prevBtn?.addEventListener('mouseenter', stopAuto);
    prevBtn?.addEventListener('mouseleave', startAuto);
    nextBtn?.addEventListener('mouseenter', stopAuto);
    nextBtn?.addEventListener('mouseleave', startAuto);

    applyPositions();
    startAuto();
  });
</script>

<script is:inline>
  (() => {
    const section = document.querySelector('.testimonios-reveal-section');
    if (!section) return;

    const items = Array.from(section.querySelectorAll('.testimonios-reveal'));
    if (!items.length) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion) {
      items.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.16,
        rootMargin: '0px 0px -8% 0px',
      }
    );

    items.forEach((item, index) => {
      item.style.setProperty('--reveal-delay', `${index * 120}ms`);
      observer.observe(item);
    });
  })();
</script>

<style>
  .testimonios-reveal{
    opacity: 0;
    transform: translate3d(0, 28px, 0) scale(.985);
    transition:
      opacity .75s ease,
      transform .75s cubic-bezier(.22,.61,.36,1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .testimonios-reveal-pill{
    transform: translate3d(0, 18px, 0) scale(.99);
  }

  .testimonios-reveal-stage{
    transform: translate3d(0, 32px, 0) scale(.985);
  }

  .testimonios-reveal.is-visible{
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (prefers-reduced-motion: reduce){
    .testimonios-reveal{
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .testimonios-stage{
    position: relative;
    height: 620px;
  }

  .testimonios-stage-wrap{
    position: relative;
  }

  .testimonios-arrow{
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 1px solid rgba(11,88,113,.10);
    border-radius: 999px;
    background: rgba(255,255,255,.92);
    color: #0B5871;
    box-shadow: 0 10px 24px rgba(0,0,0,.12);
    font-size: 26px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform .25s ease, color .25s ease, opacity .25s ease, background .25s ease, box-shadow .25s ease;
    opacity: 1;
  }

  .testimonios-arrow > span{
    display: block;
    line-height: 1;
    transform: translateY(-1px);
  }

  .testimonios-arrow-left > span{
    transform: translate(-1px, -1px);
  }

  .testimonios-arrow-right > span{
    transform: translate(1px, -1px);
  }

  .testimonios-arrow:hover{
    transform: translateY(-50%) scale(1.06);
    background: #fff;
    color: #0197C5;
    box-shadow: 0 14px 28px rgba(0,0,0,.16);
  }

  .testimonios-arrow-left{
    left: 8px;
  }

  .testimonios-arrow-right{
    right: 8px;
  }

  .testimonios-dots{
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
  }

  .testimonios-dot{
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 0;
    background: rgba(8,162,215,.28);
    cursor: pointer;
    transition: transform .25s ease, background .25s ease, opacity .25s ease;
    opacity: .9;
  }

  .testimonios-dot:hover{
    transform: scale(1.12);
    background: rgba(8,162,215,.5);
  }

  .testimonios-dot.is-active{
    background: #08a2d7;
    transform: scale(1.28);
  }

  .testimonial-card{
    position: absolute;
    top: 50%;
    left: 50%;
    width: 280px;
    border-radius: 28px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 18px 38px rgba(0,0,0,0.18);
    transform: translate(-50%, -50%) scale(.82);
    opacity: 0;
    filter: blur(2px);
    transition: transform .55s ease, opacity .55s ease, filter .55s ease, box-shadow .55s ease;
    z-index: 1;
    will-change: transform, opacity, filter;
  }

  .testimonial-image-wrap{
    height: 340px;
    overflow: hidden;
  }

  .testimonial-image{
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 2%;
  }

  .testimonial-info{
    position: relative;
    background: linear-gradient(180deg, #08a2d7 0%, #0694c7 100%);
    color: #fff;
    padding: 22px 22px 26px;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 12px;
  }

  .testimonial-info h3{
    margin: 0;
    font-size: 24px;
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .testimonial-text{
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    opacity: .96;
    text-wrap: pretty;
  }

  .testimonial-meta{
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .testimonial-role{
    display: inline-block;
    font-size: 14px;
    line-height: 1.3;
    font-weight: 600;
    opacity: .82;
  }

  .testimonial-info::before{
    content: "“";
    position: absolute;
    top: 10px;
    right: 16px;
    font-size: 58px;
    line-height: 1;
    font-weight: 800;
    color: rgba(255,255,255,.16);
    pointer-events: none;
  }

  .card-left-2{
    transform: translate(calc(-50% - 430px), -50%) scale(.84);
    z-index: 1;
    opacity: .34;
  }

  .card-left-1{
    transform: translate(calc(-50% - 260px), -50%) scale(.9);
    z-index: 2;
    opacity: .62;
  }

  .card-center{
    transform: translate(-50%, -50%) scale(1.04);
    opacity: 1;
    filter: blur(0);
    box-shadow: 0 24px 56px rgba(0,0,0,0.22);
    z-index: 4;
  }

  .card-right-1{
    transform: translate(calc(-50% + 260px), -50%) scale(.9);
    z-index: 2;
    opacity: .62;
  }

  .card-right-2{
    transform: translate(calc(-50% + 430px), -50%) scale(.84);
    z-index: 1;
    opacity: .34;
  }

  .card-left-1 .testimonial-text,
  .card-right-1 .testimonial-text,
  .card-left-2 .testimonial-text,
  .card-right-2 .testimonial-text{
    display: none;
  }

  .card-left-1 .testimonial-info,
  .card-right-1 .testimonial-info{
    min-height: 112px;
    padding: 18px 18px 20px;
    gap: 6px;
  }

  .card-left-2 .testimonial-info,
  .card-right-2 .testimonial-info{
    min-height: 96px;
    padding: 16px 16px 18px;
    gap: 4px;
  }

  .card-left-1 .testimonial-info::before,
  .card-right-1 .testimonial-info::before,
  .card-left-2 .testimonial-info::before,
  .card-right-2 .testimonial-info::before{
    display: none;
  }

  .card-left-1 .testimonial-info h3,
  .card-right-1 .testimonial-info h3{
    font-size: 18px;
  }

  .card-left-2 .testimonial-info h3,
  .card-right-2 .testimonial-info h3{
    font-size: 16px;
  }

  .card-left-1 .testimonial-role,
  .card-right-1 .testimonial-role,
  .card-left-2 .testimonial-role,
  .card-right-2 .testimonial-role{
    font-size: 12px;
    opacity: .78;
  }

  @media (min-width: 640px){
    .testimonios-stage{
      height: 660px;
    }

    .testimonial-card{
      width: 320px;
    }

    .testimonial-image-wrap{
      height: 380px;
    }

    .testimonial-info{
      padding: 24px 24px 30px;
      min-height: 228px;
      gap: 12px;
    }

    .testimonial-info h3{
      font-size: 24px;
    }

    .testimonial-text{
      margin-top: 0;
      font-size: 15px;
      line-height: 1.65;
    }

    .card-left-1{
      transform: translate(calc(-50% - 280px), -50%) scale(.9);
    }

    .card-right-1{
      transform: translate(calc(-50% + 280px), -50%) scale(.9);
    }

    .card-left-2{
      transform: translate(calc(-50% - 470px), -50%) scale(.84);
    }

    .card-center{
      transform: translate(-50%, -50%) scale(1.05);
    }

    .card-right-2{
      transform: translate(calc(-50% + 470px), -50%) scale(.84);
    }
  }

  @media (max-width: 639px){
    .testimonios-stage{
      height: 500px;
    }

    .testimonial-card{
      width: 220px;
      border-radius: 22px;
    }

    .testimonial-image-wrap{
      height: 250px;
    }
    .testimonial-image{
      object-position: center 28%;
    }

    .testimonial-info{
      padding: 16px 16px 20px;
      min-height: 152px;
      gap: 8px;
    }

    .testimonial-info h3{
      font-size: 17px;
      line-height: 1.15;
    }

    .testimonial-text{
      font-size: 12px;
      line-height: 1.5;
    }

    .card-left-2{
      transform: translate(calc(-50% - 135px), -50%) scale(.74);
      opacity: .18;
      z-index: 1;
    }

    .card-left-1{
      transform: translate(calc(-50% - 86px), -50%) scale(.82);
      opacity: .46;
      z-index: 2;
    }

    .card-center{
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      filter: blur(0);
      z-index: 4;
    }

    .card-right-1{
      transform: translate(calc(-50% + 86px), -50%) scale(.82);
      opacity: .46;
      z-index: 2;
    }

    .card-right-2{
      transform: translate(calc(-50% + 135px), -50%) scale(.74);
      opacity: .18;
      z-index: 1;
    }

    .testimonios-arrow{
      width: 34px;
      height: 34px;
      font-size: 22px;
    }

    .testimonios-arrow-left{
      left: 6px;
    }

    .testimonios-arrow-right{
      right: 6px;
    }

    .testimonios-dots{
      margin-top: 12px;
      gap: 8px;
    }

    .testimonios-dot{
      width: 8px;
      height: 8px;
    }

    .testimonial-role{
      font-size: 11px;
    }

    .testimonial-info::before{
      top: 8px;
      right: 12px;
      font-size: 42px;
    }

    .card-left-1 .testimonial-info,
    .card-right-1 .testimonial-info{
      min-height: 84px;
      padding: 14px 14px 16px;
    }

    .card-left-2 .testimonial-info,
    .card-right-2 .testimonial-info{
      min-height: 74px;
      padding: 12px 12px 14px;
    }

    .card-left-1 .testimonial-info h3,
    .card-right-1 .testimonial-info h3{
      font-size: 14px;
    }

    .card-left-2 .testimonial-info h3,
    .card-right-2 .testimonial-info h3{
      font-size: 12px;
    }
  }
</style>