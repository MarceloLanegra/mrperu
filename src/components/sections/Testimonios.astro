---
const cards = [
  {
    id: 1,
    name: "Lucía Rivera",
    role: "Directora",
    text: "testimonio",
    image: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=900&q=80",
  },
  {
    id: 2,
    name: "Lucía Rivera",
    role: "Directora",
    text: "testimonio",
    image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=900&q=80",
  },
  {
    id: 3,
    name: "Lucía Rivera",
    role: "Directora",
    text: "testimonio",
    image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=900&q=80",
    featured: true,
  },
  {
    id: 4,
    name: "Lucía Rivera",
    role: "Directora",
    text: "testimonio",
    image: "https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?auto=format&fit=crop&w=900&q=80",
  },
  {
    id: 5,
    name: "Lucía Rivera",
    role: "Directora",
    text: "testimonio",
    image: "https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=900&q=80",
  },
];

const title = "TESTIMONIOS";
---

<section id="testimonios" class=" py-8 sm:py-12 lg:py-14">
  <div class="mx-auto w-[min(1400px,calc(100%-16px))] sm:w-[min(1400px,calc(100%-24px))]">
    <div class="relative mb-8 sm:mb-10">
      <div class="h-px w-full bg-slate-200"></div>
      <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] max-w-max -translate-x-1/2 -translate-y-1/2 sm:w-auto">
        <div class="rounded-[12px] bg-white px-5 py-2 shadow-[0_10px_25px_rgba(0,0,0,0.18)] ring-1 ring-black/5 sm:rounded-[14px] sm:px-6">
          <span class="text-blue-mrperu block text-balance font-extrabold tracking-wide text-[14px] leading-tight sm:text-[16px] lg:text-[22px]">
            {title}
          </span>
        </div>
      </div>
    </div>

    <div class="relative overflow-hidden py-8 sm:py-10 lg:py-12">
      <div class="testimonios-stage-wrap">
        <button class="testimonios-arrow bg-yellow-mrperu testimonios-arrow-left" type="button" aria-label="Anterior">
          <span aria-hidden="true">‹</span>
        </button>

        <div class="testimonios-stage">
          {cards.map((card, index) => {
            return (
              <article
                class:list={["testimonial-card", index === 2 && "card-center", card.featured && "is-featured"]}
                data-testimonial-index={index}
              >
                <div class="testimonial-image-wrap">
                  <img
                    src={card.image}
                    alt={`${card.name}, ${card.role}`}
                    class="testimonial-image"
                    loading="lazy"
                    decoding="async"
                  />
                </div>

                <div class="testimonial-info">
                  <h3>{card.name} / {card.role}</h3>
                  <p>{card.text}</p>
                </div>
              </article>
            );
          })}
        </div>

        <button class="testimonios-arrow bg-yellow-mrperu text-white testimonios-arrow-right" type="button" aria-label="Siguiente">
          <span aria-hidden="true">›</span>
        </button>
      </div>

      <div class="testimonios-dots" aria-label="Indicadores del carrusel">
        {cards.map((_, index) => (
          <button
            type="button"
            class="testimonios-dot"
            data-dot-index={index}
            aria-label={`Ir al testimonio ${index + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const stages = document.querySelectorAll('.testimonios-stage');

  stages.forEach((stage) => {
    const cards = Array.from(stage.querySelectorAll('[data-testimonial-index]'));
    const wrap = stage.closest('.testimonios-stage-wrap');
    const prevBtn = wrap?.querySelector('.testimonios-arrow-left');
    const nextBtn = wrap?.querySelector('.testimonios-arrow-right');
    const dots = Array.from(wrap?.parentElement?.querySelectorAll('.testimonios-dot') || []);

    if (!cards.length) return;

    let activeIndex = 2;
    const total = cards.length;
    let interval;

    const applyPositions = () => {
      cards.forEach((card, index) => {
        card.classList.remove('card-left-2', 'card-left-1', 'card-center', 'card-right-1', 'card-right-2');

        const offset = (index - activeIndex + total) % total;
        const normalizedOffset = offset > Math.floor(total / 2) ? offset - total : offset;

        let positionClass = 'card-right-2';

        if (normalizedOffset <= -2) positionClass = 'card-left-2';
        else if (normalizedOffset === -1) positionClass = 'card-left-1';
        else if (normalizedOffset === 0) positionClass = 'card-center';
        else if (normalizedOffset === 1) positionClass = 'card-right-1';
        else if (normalizedOffset >= 2) positionClass = 'card-right-2';

        card.classList.add(positionClass);
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === activeIndex);
      });
    };

    const stopAuto = () => {
      window.clearInterval(interval);
    };

    const startAuto = () => {
      stopAuto();
      interval = window.setInterval(() => {
        activeIndex = (activeIndex + 1) % total;
        applyPositions();
      }, 2800);
    };

    const goTo = (index) => {
      activeIndex = index;
      applyPositions();
      startAuto();
    };

    const goToNext = () => {
      activeIndex = (activeIndex + 1) % total;
      applyPositions();
      startAuto();
    };

    const goToPrev = () => {
      activeIndex = (activeIndex - 1 + total) % total;
      applyPositions();
      startAuto();
    };

    prevBtn?.addEventListener('click', goToPrev);
    nextBtn?.addEventListener('click', goToNext);

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goTo(index));
    });

    stage.addEventListener('mouseenter', stopAuto);
    stage.addEventListener('mouseleave', startAuto);

    prevBtn?.addEventListener('mouseenter', stopAuto);
    prevBtn?.addEventListener('mouseleave', startAuto);
    nextBtn?.addEventListener('mouseenter', stopAuto);
    nextBtn?.addEventListener('mouseleave', startAuto);

    applyPositions();
    startAuto();
  });
</script>

<style>
  .testimonios-stage{
    position: relative;
    height: 470px;
  }

  .testimonios-stage-wrap{
    position: relative;
  }

  .testimonios-arrow{
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 42px;
    height: 42px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    color: #fff;
    font-size: 28px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
  }

  .testimonios-arrow > span{
    display: block;
    line-height: 1;
    transform: translateY(-1px);
  }

  .testimonios-arrow-left > span{
    transform: translate(-1px, -1px);
  }

  .testimonios-arrow-right > span{
    transform: translate(1px, -1px);
  }

  .testimonios-arrow:hover{
    transform: translateY(-50%) scale(1.06);
  }

  .testimonios-arrow-left{
    left: 8px;
  }

  .testimonios-arrow-right{
    right: 8px;
  }

  .testimonios-dots{
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
  }

  .testimonios-dot{
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 0;
    background: rgba(8,162,215,.28);
    cursor: pointer;
    transition: transform .25s ease, background .25s ease, opacity .25s ease;
    opacity: .9;
  }

  .testimonios-dot:hover{
    transform: scale(1.12);
    background: rgba(8,162,215,.5);
  }

  .testimonios-dot.is-active{
    background: #08a2d7;
    transform: scale(1.28);
  }

  .testimonial-card{
    position: absolute;
    top: 50%;
    left: 50%;
    width: 190px;
    border-radius: 24px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 18px 38px rgba(0,0,0,0.18);
    transform: translate(-50%, -50%) scale(.82);
    opacity: 0;
    filter: blur(2px);
    transition: transform .55s ease, opacity .55s ease, filter .55s ease, box-shadow .55s ease;
    z-index: 1;
    will-change: transform, opacity, filter;
  }

  .testimonial-image-wrap{
    height: 250px;
    overflow: hidden;
  }

  .testimonial-image{
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-info{
    background: #08a2d7;
    color: #fff;
    padding: 14px 14px 18px;
    min-height: 98px;
  }

  .testimonial-info h3{
    margin: 0;
    font-size: 13px;
    line-height: 1.25;
    font-weight: 400;
  }

  .testimonial-info p{
    margin: 4px 0 0;
    font-size: 11px;
    line-height: 1.35;
    opacity: .95;
  }

  .card-left-2{
    transform: translate(calc(-50% - 310px), -50%) scale(.82);
    z-index: 1;
    opacity: .42;
  }

  .card-left-1{
    transform: translate(calc(-50% - 155px), -50%) scale(.9);
    z-index: 2;
    opacity: .72;
  }

  .card-center{
    transform: translate(-50%, -50%) scale(1.06);
    opacity: 1;
    filter: blur(0);
    box-shadow: 0 24px 56px rgba(0,0,0,0.22);
    z-index: 3;
  }

  .card-right-1{
    transform: translate(calc(-50% + 155px), -50%) scale(.9);
    z-index: 2;
    opacity: .72;
  }

  .card-right-2{
    transform: translate(calc(-50% + 310px), -50%) scale(.82);
    z-index: 1;
    opacity: .42;
  }

  @media (min-width: 640px){
    .testimonios-stage{
      height: 520px;
    }

    .testimonial-card{
      width: 240px;
    }

    .testimonial-image-wrap{
      height: 320px;
    }

    .testimonial-info{
      padding: 18px 18px 22px;
      min-height: 114px;
    }

    .testimonial-info h3{
      font-size: 18px;
    }

    .testimonial-info p{
      margin-top: 6px;
      font-size: 14px;
    }

    .card-left-2{
      transform: translate(calc(-50% - 400px), -50%) scale(.84);
    }

    .card-left-1{
      transform: translate(calc(-50% - 210px), -50%) scale(.92);
    }

    .card-center{
      transform: translate(-50%, -50%) scale(1.06);
    }

    .card-right-1{
      transform: translate(calc(-50% + 210px), -50%) scale(.92);
    }

    .card-right-2{
      transform: translate(calc(-50% + 400px), -50%) scale(.84);
    }
  }

  @media (max-width: 639px){
    .testimonios-stage{
      height: 420px;
    }

    .testimonial-card{
      width: 170px;
      border-radius: 20px;
    }

    .testimonial-image-wrap{
      height: 220px;
    }

    .testimonial-info{
      padding: 12px 12px 16px;
      min-height: 88px;
    }

    .testimonial-info h3{
      font-size: 12px;
    }

    .testimonial-info p{
      font-size: 10px;
    }

    .card-left-2{
      transform: translate(calc(-50% - 118px), -50%) scale(.72);
      opacity: .24;
      z-index: 1;
    }

    .card-left-1{
      transform: translate(calc(-50% - 58px), -50%) scale(.82);
      opacity: .55;
      z-index: 2;
    }

    .card-center{
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      filter: blur(0);
      z-index: 4;
    }

    .card-right-1{
      transform: translate(calc(-50% + 58px), -50%) scale(.82);
      opacity: .55;
      z-index: 2;
    }

    .card-right-2{
      transform: translate(calc(-50% + 118px), -50%) scale(.72);
      opacity: .24;
      z-index: 1;
    }

    .testimonios-arrow{
      width: 36px;
      height: 36px;
      font-size: 24px;
    }

    .testimonios-arrow-left{
      left: 2px;
    }

    .testimonios-arrow-right{
      right: 2px;
    }

    .testimonios-dots{
      margin-top: 12px;
      gap: 8px;
    }

    .testimonios-dot{
      width: 8px;
      height: 8px;
    }
  }
</style>