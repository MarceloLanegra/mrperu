---
const title = "CONOCE MÁS DE NUESTROS EQUIPOS";


const reels = [
  {
    id: "r1",
    src: "/reels-equipos/020625-MRPERU-EVELIN-VALDIVIA-33-ANOS.mp4",
    poster: "/thumbs/reels-equipos/020625-MRPERU-EVELIN-VALDIVIA-33-ANOS.jpg",
    caption: "33 años de experiencia",
  },
  {
    id: "r2",
    src: "/reels-equipos/021325-MRPERU-Reducciones-ALDO-MORI.mp4",
    poster: "/thumbs/reels-equipos/021325-MRPERU-Reducciones-ALDO-MORI.jpg",
    caption: "Reducciones eficientes",
  },
  {
    id: "r3",
    src: "/reels-equipos/021325-MRPERU-EVELIN-VALIVIACOMPRESORCONTANQUE.mp4",
    poster: "/thumbs/reels-equipos/021325-MRPERU-EVELIN-VALIVIACOMPRESORCONTANQUE.jpg",
    caption: "Compresor con tanque",
  },
  {
    id: "r4",
    src: "/reels-equipos/020625-MRPERU-EVELIN-VALDIVIA.mp4",
    poster: "/thumbs/reels-equipos/020625-MRPERU-EVELIN-VALDIVIA.jpg",
    caption: "Conoce nuestros equipos",

  },
  {
    id: "r5",
    src: "/reels-equipos/022425-MRPERU-Ads_GA11VSDs_01.mp4",
    poster: "/thumbs/reels-equipos/022425-MRPERU-Ads_GA11VSDs_01.jpg",
    caption: "GA11 VSDs",
  },
  {
    id: "r6",
    src: "/reels-equipos/022425-MRPERU-Ads_GA11VSDs_02.mp4",
    poster: "/thumbs/reels-equipos/022425-MRPERU-Ads_GA11VSDs_02.jpg",
    caption: "GA11 VSDs",
  },
  {
    id: "r7",
    src: "/reels-equipos/022425-MRPERU-Ads_GA18VSDs_01.mp4",
    poster: "/thumbs/reels-equipos/022425-MRPERU-Ads_GA18VSDs_01.jpg",
    caption: "GA18 VSDs",
  },
];
---

<section id="equipos" class="bg-white py-12 sm:pb-16">
  <div class="mx-auto w-[min(1400px,calc(100%-24px))]">
    <!-- pill title -->
    <div class="relative mb-10 sm:mb-14 lg:mb-16">
      <div class="h-px w-full bg-slate-200"></div>
      <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] sm:w-auto sm:min-w-[520px] lg:min-w-[620px] -translate-x-1/2 -translate-y-1/2 mb-2">
        <div class="rounded-[12px] bg-white px-4 py-2 sm:px-8 shadow-[0_10px_25px_rgba(0,0,0,0.18)] ring-1 ring-black/5 sm:rounded-[14px]">
          <span class="text-blue-mrperu block text-center text-balance font-extrabold tracking-wide text-[14px] leading-tight sm:text-[16px] lg:text-[24px]">
            {title}
          </span>
        </div>
      </div>
    </div>

    <div class="relative mt-3 sm:mt-4 lg:mt-5">
      <button type="button" class="reels-arrow reels-arrow-left" aria-label="Reel anterior">
        <span aria-hidden="true">‹</span>
      </button>

      <button type="button" class="reels-arrow reels-arrow-right" aria-label="Reel siguiente">
        <span aria-hidden="true">›</span>
      </button>

      <div id="reelsTrack" class="reels-track">
        {reels.map((r, i) => (
          <button
            type="button"
            class={`reel-card ${i === 0 ? "is-active" : ""}`}
            data-reel-index={i}
            data-src={r.src}
            data-poster={r.poster}
            aria-label={`Abrir reel ${i + 1}`}
          >
            <img src={r.poster} alt="" class="reel-thumb" loading="lazy" decoding="async" />

            <!-- play icon -->
            <span class="reel-play" aria-hidden="true">▶</span>

            <!-- caption (si quieres) -->
            <span class="reel-caption">
              <strong>{r.caption}</strong>
              <small>las mejores máquinas para ti</small>
            </span>
          </button>
        ))}
      </div>


    </div>
  </div>

  <!-- Modal -->
  <div id="reelModal" class="modal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>

    <div class="modal-panel" role="dialog" aria-modal="true" aria-label="Video">
      <button class="modal-close" type="button" data-close aria-label="Cerrar">✕</button>

      <video
        id="reelPlayer"
        class="modal-video"
        controls
        playsinline
        preload="metadata"
      >
        <source id="reelSource" src="" type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<style>
  /* === Track (scroll + snap) === */
  .reels-track{
    display:flex;
    gap:22px;
    overflow-x:auto;
    padding: 10px 44px 18px;
    scroll-snap-type: x mandatory;
    scroll-behavior:smooth;
    scrollbar-width:none;
  }
  .reels-track::-webkit-scrollbar{ display:none; }

  /* === Card === */
  .reel-card{
    position:relative;
    flex: 0 0 auto;
    scroll-snap-align:start;
    scroll-snap-stop: always;

    width: 260px;
    height: 460px;

    border-radius: 26px;
    overflow:hidden;
    background:#fff;
    border: 1px solid rgba(0,0,0,0.06);


    transform: scale(0.88);
    opacity: 0.72;
    transition: transform .25s ease, opacity .25s ease;
  }

  .reel-card.is-active{
    transform: scale(1);
    opacity: 1;
  }

  .reel-thumb{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }

  .reel-play{
    position:absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    border-radius: 999px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-weight:900;
    color:#0197C5;
    background: rgba(255,255,255,0.92);
    box-shadow: 0 12px 30px rgba(0,0,0,0.25);
  }

  .reel-caption{
    position:absolute;
    left: 0;
    right: 0;
    bottom: 14px;
    text-align:center;
    color:#fff;
    padding: 0 10px;
    text-shadow: 0 10px 24px rgba(0,0,0,0.45);
  }
  .reel-caption strong{ display:block; font-weight:900; font-size:14px; }
  .reel-caption small{ display:block; font-size:11px; opacity:.95; }

  .reels-arrow{
    position:absolute;
    top:50%;
    z-index:3;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:40px;
    height:40px;
    padding:0;
    border:1px solid rgba(11,88,113,.10);
    border-radius:999px;
    background:rgba(255,255,255,.92);
    color:#0B5871;
    box-shadow:0 10px 24px rgba(0,0,0,.12);
    cursor:pointer;
    transform:translateY(-50%);
    transition:transform .25s ease, color .25s ease, opacity .25s ease, background .25s ease, box-shadow .25s ease;
    opacity:1;
  }

  .reels-arrow:hover{
    transform:translateY(-50%) scale(1.06);
    background:#fff;
    color:#0197C5;
    box-shadow:0 14px 28px rgba(0,0,0,.16);
  }

  .reels-arrow > span{
    display:block;
    font-size:26px;
    font-weight:700;
    line-height:1;
    text-shadow:none;
    transform:translateY(-1px);
  }

  .reels-arrow-left{ left:8px; }
  .reels-arrow-right{ right:8px; }

  @media (max-width: 640px){
    .reel-card{ width: 220px; height: 390px; }
    .reel-play{ width: 58px; height: 58px; }
    .reels-track{ padding: 10px 34px 18px; }
    .reels-arrow{ width:34px; height:34px; }
    .reels-arrow > span{ font-size:22px; }
    .reels-arrow-left{ left:2px; }
    .reels-arrow-right{ right:2px; }
  }

  /* === Modal === */
  .modal{ position:fixed; inset:0; display:none; z-index:80; }
  .modal.is-open{ display:block; }
  .modal-backdrop{ position:absolute; inset:0; background: rgba(0,0,0,0.55); }
  .modal-panel{
    position:relative;
    width: min(520px, calc(100% - 24px));
    margin: 6vh auto 0;
    background:#fff;
    border-radius: 22px;
    overflow:hidden;
    box-shadow: 0 30px 90px rgba(0,0,0,0.35);
  }
  .modal-close{
    position:absolute;
    right:10px;
    top:10px;
    width:40px;
    height:40px;
    border-radius: 999px;
    background: rgba(255,255,255,0.95);
    border: 1px solid rgba(0,0,0,0.08);
    font-weight:900;
  }
  .modal-video{
    width:100%;
    aspect-ratio: 9 / 16;
    background:#000;
    display:block;
    object-fit:cover;
  }
</style>

<script is:inline>
  const track = document.getElementById("reelsTrack");
  const modal = document.getElementById("reelModal");
  const player = document.getElementById("reelPlayer");
  const source = document.getElementById("reelSource");

  // --- Active card (left-most visible) ---
  const setActive = () => {
    if (!track) return;
    const cards = [...track.querySelectorAll(".reel-card")];
    const trackRect = track.getBoundingClientRect();

    let best = null;
    let bestDist = Infinity;

    cards.forEach((c) => {
      const r = c.getBoundingClientRect();

      // must be at least partially visible inside the track viewport
      const isVisible = r.right > trackRect.left + 10 && r.left < trackRect.right - 10;
      if (!isVisible) return;

      // distance from track's left edge to card's left edge
      const dist = Math.abs(r.left - trackRect.left);
      if (dist < bestDist) {
        bestDist = dist;
        best = c;
      }
    });

    if (!best) best = cards[0];
    const activeIndex = best?.getAttribute("data-reel-index");
    cards.forEach((c) => c.classList.toggle("is-active", c.getAttribute("data-reel-index") === activeIndex));
  };

  let raf = null;
  const onScroll = () => {
    if (raf) return;
    raf = requestAnimationFrame(() => {
      raf = null;
      normalizeInfiniteScroll();
      setActive();
    });
  };

  const dots = [...document.querySelectorAll(".reels-dot[data-reel-dot]")];
  const prevArrow = document.querySelector(".reels-arrow-left");
  const nextArrow = document.querySelector(".reels-arrow-right");

  let loopReady = false;
  let loopSegmentWidth = 0;
  let loopResetting = false;

  const setupInfiniteLoop = () => {
    if (!track || loopReady) return;

    const originals = [...track.querySelectorAll('.reel-card:not([data-clone])')];
    if (!originals.length) return;

    const beforeFragment = document.createDocumentFragment();
    const afterFragment = document.createDocumentFragment();

    originals.forEach((card) => {
      const beforeClone = card.cloneNode(true);
      beforeClone.classList.remove('is-active');
      beforeClone.setAttribute('data-clone', 'before');
      beforeFragment.appendChild(beforeClone);

      const afterClone = card.cloneNode(true);
      afterClone.classList.remove('is-active');
      afterClone.setAttribute('data-clone', 'after');
      afterFragment.appendChild(afterClone);
    });

    track.prepend(beforeFragment);
    track.append(afterFragment);

    const firstOriginal = track.querySelector('.reel-card[data-reel-index="0"]:not([data-clone])');
    const firstAfterClone = track.querySelector('.reel-card[data-reel-index="0"][data-clone="after"]');

    if (!firstOriginal || !firstAfterClone) return;

    loopSegmentWidth = firstAfterClone.offsetLeft - firstOriginal.offsetLeft;
    track.scrollLeft = firstOriginal.offsetLeft;
    loopReady = true;
  };

  const normalizeInfiniteScroll = () => {
    if (!track || !loopReady || !loopSegmentWidth || loopResetting) return;

    const firstOriginal = track.querySelector('.reel-card[data-reel-index="0"]:not([data-clone])');
    const firstAfterClone = track.querySelector('.reel-card[data-reel-index="0"][data-clone="after"]');
    if (!firstOriginal || !firstAfterClone) return;

    const minEdge = firstOriginal.offsetLeft - 12;
    const maxEdge = firstAfterClone.offsetLeft - 12;

    if (track.scrollLeft <= minEdge) {
      loopResetting = true;
      track.scrollLeft += loopSegmentWidth;
      loopResetting = false;
    } else if (track.scrollLeft >= maxEdge) {
      loopResetting = true;
      track.scrollLeft -= loopSegmentWidth;
      loopResetting = false;
    }
  };

  if (track) {
    setupInfiniteLoop();
    setActive();
    track.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      loopReady = false;
      loopSegmentWidth = 0;
      const clones = track.querySelectorAll('.reel-card[data-clone]');
      clones.forEach((clone) => clone.remove());
      setupInfiniteLoop();
      setActive();
    });
  }

  // --- Modal open/close ---
  const openModal = (src, poster) => {
    if (!modal || !player || !source) return;
    source.src = src;
    player.poster = poster || "";
    player.load();
    modal.classList.add("is-open");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };

  const closeModal = () => {
    if (!modal || !player || !source) return;
    player.pause();
    source.src = "";
    player.load();
    modal.classList.remove("is-open");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  };

  document.addEventListener("click", (event) => {
    const btn = event.target.closest("#reelsTrack .reel-card");
    if (!btn) return;

    const src = btn.getAttribute("data-src");
    const poster = btn.getAttribute("data-poster");
    if (src) openModal(src, poster);
  });

  document.querySelectorAll("[data-close]").forEach((el) => el.addEventListener("click", closeModal));
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

  dots.forEach((dot, index) => {
    dot.addEventListener("click", () => {
      const cards = [...document.querySelectorAll("#reelsTrack .reel-card")];
      const target = cards[index];
      if (!target) return;

      target.scrollIntoView({
        behavior: "smooth",
        inline: "start",
        block: "nearest",
      });

      window.setTimeout(() => {
        setActive();
      }, 250);
    });
  });

  const scrollToCard = (direction) => {
    if (!track) return;

    const firstCard = track.querySelector('.reel-card');
    if (!firstCard) return;

    const cardStyles = window.getComputedStyle(firstCard);
    const cardWidth = firstCard.getBoundingClientRect().width;
    const gap = parseFloat(cardStyles.marginRight || '0') || 22;
    const step = cardWidth + gap;

    track.scrollBy({
      left: direction * step,
      behavior: 'smooth',
    });

    window.setTimeout(() => {
      normalizeInfiniteScroll();
      setActive();
    }, 280);
  };

  prevArrow?.addEventListener("click", () => scrollToCard(-1));
  nextArrow?.addEventListener("click", () => scrollToCard(1));
</script>