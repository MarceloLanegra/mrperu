---
const title = "CASOS DE ÉXITO";

// Cambia estos paths por los tuyos (ideal: mp4 en /public/videos y thumbs en /public/thumbs)
const videos = [
  {
    id: "caso-1",
    label: "Planta de arándanos",
    src: "/casos-exito/1.planta-de-arandanos.mp4",
    poster: "/thumbs/casos-exito/1.planta-de-arandanos.jpg",
  },
  {
    id: "caso-2",
    label: "Arranque inicial de un compresor GA-30-VSDs",
    src: "/casos-exito/2.Arranque-inicial-de-un-compresor-GA-30-VSDs.mp4",
    poster: "/thumbs/casos-exito/2.Arranque-inicial-de-un-compresor-GA-30-VSDs.jpg",
  },
  {
    id: "caso-3",
    label: "VSDs en plena acción en planta procesadora de granos",
    src: "/casos-exito/3.VSDs-en-plena-accion-en-planta-procesadora-de-granos.mp4",
    poster: "/thumbs/casos-exito/3.VSDs-en-plena-accion-en-planta-procesadora-de-granos.jpg",
  },
  {
    id: "caso-4",
    label: "Puesta en marcha de compresores VSDs en planta OSLO Punta Negra",
    src: "/casos-exito/4.Planta-OSLO-Punta-Negra.mp4",
    poster: "/thumbs/casos-exito/4.Planta-OSLO-Punta-Negra.jpg",
  },
  {
    id: "caso-5",
    label: "Compresor VSD en planta de fabricación de techos",
    src: "/casos-exito/5.Compresor-VSD-en-planta-de-fabricacion-de-techos.mp4",
    poster: "/thumbs/casos-exito/5.Compresor-VSD-en-planta-de-fabricacion-de-techos.jpg",
  },
];

// Por defecto mostramos el primero en grande
const main = videos[0];
const list = videos.slice(1);
---

<section id="casos-de-exito" class="bg-white py-8 sm:py-12 lg:py-14 scroll-mt-24">
  <div class="mx-auto w-[min(1400px,calc(100%-16px))] sm:w-[min(1400px,calc(100%-24px))]">
    <!-- Pill título -->
    <div class="relative mb-10 sm:mb-14 lg:mb-16">
      <div class="h-px w-full bg-slate-200"></div>
      <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] sm:w-auto sm:min-w-[520px] lg:min-w-[420px] -translate-x-1/2 -translate-y-1/2 mb-2">
        <div class="rounded-[12px] bg-white px-4 py-2 sm:px-8 shadow-[0_10px_25px_rgba(0,0,0,0.18)] ring-1 ring-black/5 sm:rounded-[14px]">
          <span class="text-blue-mrperu block text-center text-balance font-extrabold tracking-wide text-[16px] leading-tight sm:text-[18px] lg:text-[26px]">
            {title}
          </span>
        </div>
      </div>
    </div>

    <!-- Layout: grande + listado de videos -->
    <div class="grid gap-4 sm:gap-5 lg:gap-6 mt-3 sm:mt-4 lg:mt-5 md:grid-cols-[1.35fr_0.65fr] md:items-start">
      <!-- Player grande -->
      <div class="overflow-hidden rounded-[16px] bg-white shadow-[0_14px_28px_rgba(0,0,0,0.14)] sm:rounded-[20px] sm:shadow-[0_16px_34px_rgba(0,0,0,0.16)] lg:rounded-[22px] lg:shadow-[0_22px_60px_rgba(0,0,0,0.22)]">
        <video
          id="casos-main-video"
          class="block w-full aspect-video object-cover"
          controls
          playsinline
          preload="metadata"
          poster={main.poster}
          data-src={main.src}
        >
          <source id="casos-main-source" src={main.src} type="video/mp4" />
          Tu navegador no soporta videos HTML5.
        </video>
      </div>

      <!-- Lista lateral / carrusel en mobile -->
      <div class="casos-scroll flex gap-4 overflow-x-auto bg-transparent pb-2 pr-1 md:grid md:max-h-[540px] md:grid-cols-1 md:gap-4 md:overflow-y-auto md:overflow-x-hidden md:pb-0">
        {list.map((t) => (
          <button
            type="button"
            class="casos-thumb group relative min-w-[260px] overflow-hidden rounded-[14px] bg-white text-left shadow-[0_12px_24px_rgba(0,0,0,0.14)] transition hover:-translate-y-0.5 hover:shadow-[0_16px_32px_rgba(0,0,0,0.16)] focus:outline-none focus:ring-0 focus-visible:outline-none focus-visible:ring-0 sm:min-w-[300px] sm:rounded-[18px] sm:shadow-[0_14px_34px_rgba(0,0,0,0.16)] md:min-w-0"
            data-video-src={t.src}
            data-video-poster={t.poster}
            data-video-label={t.label}
            aria-label={`Ver ${t.label}`}
          >
            <div class="relative">
              <img
                src={t.poster}
                alt={t.label}
                data-thumb-image
                class="block w-full aspect-video object-cover"
                loading="lazy"
                decoding="async"
              />
              <span class="absolute inset-0 bg-black/0 transition group-hover:bg-black/10"></span>
              <span class="absolute left-2 bottom-2 bg-white inline-flex items-center gap-1.5 rounded-full px-2 py-1 text-[10px] font-extrabold text-[#0B5871] shadow sm:left-3 sm:bottom-3 sm:gap-2 sm:px-3 sm:text-xs">
                ▶ Ver
              </span>
            </div>
            <span data-thumb-label class="block bg-white px-3 py-3 text-sm font-bold leading-snug text-slate-800 sm:px-4">
              {t.label}
            </span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const mainVideo = document.getElementById("casos-main-video");
  const mainSource = document.getElementById("casos-main-source");

  if (mainVideo && mainSource) {
    const buttons = document.querySelectorAll(".casos-thumb[data-video-src][data-video-poster]");

    const scrollArea = document.querySelector(".casos-scroll");
    let currentMain = {
      src: mainSource.getAttribute("src") || "",
      poster: mainVideo.getAttribute("poster") || "",
      label: "Planta de arándanos",
    };

    if (scrollArea) {
      let isDown = false;
      let startX = 0;
      let startY = 0;
      let scrollLeft = 0;
      let scrollTop = 0;

      const onPointerDown = (event) => {
        isDown = true;
        scrollArea.classList.add("is-dragging");
        startX = event.pageX;
        startY = event.pageY;
        scrollLeft = scrollArea.scrollLeft;
        scrollTop = scrollArea.scrollTop;
      };

      const onPointerMove = (event) => {
        if (!isDown) return;
        event.preventDefault();

        const walkX = event.pageX - startX;
        const walkY = event.pageY - startY;

        if (window.innerWidth >= 768) {
          scrollArea.scrollTop = scrollTop - walkY;
        } else {
          scrollArea.scrollLeft = scrollLeft - walkX;
        }
      };

      const stopDragging = () => {
        isDown = false;
        scrollArea.classList.remove("is-dragging");
      };

      scrollArea.addEventListener("mousedown", onPointerDown);
      scrollArea.addEventListener("mousemove", onPointerMove);
      scrollArea.addEventListener("mouseleave", stopDragging);
      window.addEventListener("mouseup", stopDragging);
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const nextSrc = btn.getAttribute("data-video-src");
        const nextPoster = btn.getAttribute("data-video-poster");
        const nextLabel = btn.getAttribute("data-video-label") || "";
        if (!nextSrc) return;

        const previousMain = { ...currentMain };

        mainVideo.pause();
        mainVideo.currentTime = 0;
        mainVideo.setAttribute("poster", nextPoster || "");
        mainSource.setAttribute("src", nextSrc);
        mainVideo.load();
        mainVideo.play().catch(() => {});

        currentMain = {
          src: nextSrc,
          poster: nextPoster || "",
          label: nextLabel,
        };

        btn.setAttribute("data-video-src", previousMain.src);
        btn.setAttribute("data-video-poster", previousMain.poster);
        btn.setAttribute("data-video-label", previousMain.label);

        const thumbImage = btn.querySelector("[data-thumb-image]");
        const thumbLabel = btn.querySelector("[data-thumb-label]");

        if (thumbImage) {
          thumbImage.setAttribute("src", previousMain.poster);
          thumbImage.setAttribute("alt", previousMain.label);
        }

        btn.setAttribute("aria-label", `Ver ${previousMain.label}`);

        if (thumbLabel) {
          thumbLabel.textContent = previousMain.label;
        }

        if (scrollArea) {
          scrollArea.appendChild(btn);
        }
      });
    });
  }
</script>
<style>
  .casos-scroll {
    cursor: grab;
    scrollbar-width: thin;
  }

  .casos-scroll.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .casos-scroll.is-dragging * {
    user-select: none;
  }
</style>