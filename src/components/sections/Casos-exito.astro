---
const title = "CASOS DE ÉXITO";

// Cambia estos paths por los tuyos (ideal: mp4 en /public/videos y thumbs en /public/thumbs)
const videos = [
  {
    id: "caso-1",
    label: "MR Chincha Arándanos",
    src: "/casos-exito/MR-CHINCHA-ARANDANOS-30seg.mp4",
    poster: "/thumbs/MR-CHINCHA-ARANDANOS-30seg.jpg",

  },
  {
    id: "caso-2",
    label: "MR Chincha Frescos",
    src: "/casos-exito/MR-CHINCHA-FRESCOS-30seg.mp4",
    poster: "/thumbs/MR-CHINCHA-FRESCOS-30seg.jpg",
  },
  {
    id: "caso-3",
    label: "Planta generadora de oxígeno",
    src: "/casos-exito/Planta-Generadora-de-Oxigeno-compresor-Atlas-Copco.mp4",
    poster: "/thumbs/Planta-Generadora-de-Oxigeno-compresor-Atlas-Copco.jpg",
  },
  {
    id: "caso-4",
    label: "Instalación VSD en supermercados peruanos Punta Negra",
    src: "/casos-exito/INSTALACION-VSD-EN-SUPERMERCADOS-PERUANOS-PUNTA-NEGRA.mp4",
    poster: "/thumbs/INSTALACION-VSD-EN-SUPERMERCADOS-PERUANOS-PUNTA-NEGRA.jpg",
  },
  {
    id: "caso-5",
    label: "Compresor VSD en plata de fabricacion de techos",
    src: "/casos-exito/Compresor-VSD-en-planta-de-fabricacion-de-techos.mp4",
    poster: "/thumbs/Compresor-VSD-en-planta-de-fabricacion-de-techos.jpg",
  },
  {
    id: "caso-6",
    label: "Mantenimiento Compresor GA 90",
    src: "/casos-exito/mantenimiento-compresor-GA-90.mp4",
    poster: "/thumbs/mantenimiento-compresor-GA-90.jpg",
  },
  {
    id: "caso-7",
    label: "Secadores vendidos en mecanoplast",
    src: "/casos-exito/SECADORES-VENDIDOS-EN-MECANOPLAST.mp4",
    poster: "/thumbs/SECADORES-VENDIDOS-EN-MECANOPLAST.jpg",
  },
  {
    id: "caso-8",
    label: "VSD NUEVA INSTALACION",
    src: "/casos-exito/VSDnuevainstalacion.mp4",
    poster: "/thumbs/VSDnuevainstalacion.jpg",
  },
];

// Por defecto mostramos el primero en grande
const main = videos[0];
const list = videos.slice(1);
---

<section id="casos-de-exito" class="bg-white py-8 sm:py-12 lg:py-14 scroll-mt-24">
  <div class="mx-auto w-[min(1400px,calc(100%-16px))] sm:w-[min(1400px,calc(100%-24px))]">
    <!-- Pill título -->
    <div class="relative mb-5 sm:mb-8 lg:mb-10">
      <div class="h-px w-full bg-slate-200"></div>
      <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] max-w-max -translate-x-1/2 -translate-y-1/2 sm:w-auto">
        <div class="rounded-[12px] bg-white px-3 py-2 shadow-[0_10px_25px_rgba(0,0,0,0.18)] ring-1 ring-black/5 sm:rounded-[14px] sm:px-6">
          <span class="text-blue-mrperu block text-balance font-extrabold tracking-wide text-[12px] leading-tight sm:text-[14px] lg:text-[22px]">
            {title}
          </span>
        </div>
      </div>
    </div>

    <!-- Layout: grande + listado de videos -->
    <div class="grid gap-4 sm:gap-5 lg:gap-6 md:grid-cols-[1.35fr_0.65fr] md:items-start">
      <!-- Player grande -->
      <div class="overflow-hidden rounded-[16px] bg-white shadow-[0_14px_28px_rgba(0,0,0,0.14)] sm:rounded-[20px] sm:shadow-[0_16px_34px_rgba(0,0,0,0.16)] lg:rounded-[22px] lg:shadow-[0_22px_60px_rgba(0,0,0,0.22)]">
        <video
          id="casos-main-video"
          class="block w-full aspect-video object-cover"
          controls
          playsinline
          preload="metadata"
          poster={main.poster}
          data-src={main.src}
        >
          <source id="casos-main-source" src={main.src} type="video/mp4" />
          Tu navegador no soporta videos HTML5.
        </video>
      </div>

      <!-- Lista lateral / carrusel en mobile -->
      <div class="flex gap-4 overflow-x-auto bg-transparent pb-2 md:grid md:max-h-[540px] md:grid-cols-1 md:gap-4 md:overflow-y-auto md:overflow-x-hidden md:pb-0 pr-1">
        {list.map((t) => (
          <button
            type="button"
            class="casos-thumb group relative min-w-[260px] overflow-hidden rounded-[14px] bg-white text-left shadow-[0_12px_24px_rgba(0,0,0,0.14)] transition hover:-translate-y-0.5 hover:shadow-[0_16px_32px_rgba(0,0,0,0.16)] focus:outline-none focus:ring-2 sm:min-w-[300px] sm:rounded-[18px] sm:shadow-[0_14px_34px_rgba(0,0,0,0.16)] md:min-w-0"
            data-video-src={t.src}
            data-video-poster={t.poster}
            aria-label={`Ver ${t.label}`}
          >
            <div class="relative">
              <img
                src={t.poster}
                alt={t.label}
                class="block w-full aspect-video object-cover"
                loading="lazy"
                decoding="async"
              />
              <span class="absolute inset-0 bg-black/0 transition group-hover:bg-black/10"></span>
              <span class="absolute left-2 bottom-2 bg-white inline-flex items-center gap-1.5 rounded-full px-2 py-1 text-[10px] font-extrabold text-[#0B5871] shadow sm:left-3 sm:bottom-3 sm:gap-2 sm:px-3 sm:text-xs">
                ▶ Ver
              </span>
            </div>
            <span class="block bg-white px-3 py-3 text-sm font-bold leading-snug text-slate-800 sm:px-4">
              {t.label}
            </span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const mainVideo = document.getElementById("casos-main-video");
  const mainSource = document.getElementById("casos-main-source");

  if (mainVideo && mainSource) {
    const buttons = document.querySelectorAll(".casos-thumb[data-video-src][data-video-poster]");

    buttons.forEach((btn, index) => {
      btn.addEventListener("click", () => {
        const src = btn.getAttribute("data-video-src");
        const poster = btn.getAttribute("data-video-poster");
        if (!src) return;
        mainVideo.pause();
        mainVideo.currentTime = 0;
        mainVideo.setAttribute("poster", poster || "");
        mainSource.setAttribute("src", src);
        mainVideo.load();
        setActive(btn);
        mainVideo.play().catch(() => {});
      });
    });
  }
</script>