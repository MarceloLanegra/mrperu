---
const title = "CASOS DE ÉXITO";

// Cambia estos paths por los tuyos (ideal: mp4 en /public/videos y thumbs en /public/thumbs)
const videos = [
  {
    id: "caso-1",
    label: "Caso 1",
    src: "/videos/caso-principal.mp4",
    poster: "/thumbs/caso-principal.jpg",
  },
  {
    id: "caso-2",
    label: "Caso 2",
    src: "/videos/caso-2.mp4",
    poster: "/thumbs/caso-2.jpg",
  },
  {
    id: "caso-3",
    label: "Caso 3",
    src: "/videos/caso-3.mp4",
    poster: "/thumbs/caso-3.jpg",
  },
];

// Por defecto mostramos el primero en grande
const main = videos[0];
const thumbs = videos.slice(1, 3); // 2 thumbnails
---

<section id="casos" class="bg-white py-8 sm:py-12 lg:py-14">
  <div class="mx-auto w-[min(1400px,calc(100%-16px))] sm:w-[min(1400px,calc(100%-24px))]">
    <!-- Pill título -->
    <div class="relative mb-5 sm:mb-8 lg:mb-10">
      <div class="h-px w-full bg-slate-200"></div>
      <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] max-w-max -translate-x-1/2 -translate-y-1/2 sm:w-auto">
        <div class="rounded-[12px] bg-white px-3 py-2 shadow-[0_10px_25px_rgba(0,0,0,0.18)] ring-1 ring-black/5 sm:rounded-[14px] sm:px-6">
          <span class="text-blue-mrperu block text-balance font-extrabold tracking-wide text-[12px] leading-tight sm:text-[14px] lg:text-[16px]">
            {title}
          </span>
        </div>
      </div>
    </div>

    <!-- Layout: grande + thumbs -->
    <div class="grid gap-4 sm:gap-5 lg:gap-6 md:grid-cols-[1.35fr_0.65fr] md:items-stretch">
      <!-- Player grande -->
      <div class="overflow-hidden rounded-[16px] bg-white shadow-[0_14px_28px_rgba(0,0,0,0.14)] ring-1 ring-black/5 sm:rounded-[20px] sm:shadow-[0_16px_34px_rgba(0,0,0,0.16)] lg:rounded-[22px] lg:shadow-[0_22px_60px_rgba(0,0,0,0.22)]">
        <video
          id="casos-main-video"
          class="block w-full aspect-video bg-black object-cover"
          controls
          playsinline
          preload="metadata"
          poster={main.poster}
          data-src={main.src}
        >
          <source id="casos-main-source" src={main.src} type="video/mp4" />
          Tu navegador no soporta videos HTML5.
        </video>
      </div>

      <!-- Thumbnails (2) -->
      <div class="grid grid-cols-1 gap-4 sm:gap-5 lg:gap-6 md:grid-cols-1 md:grid-rows-2">
        {thumbs.map((t) => (
          <button
            type="button"
            class="group relative overflow-hidden rounded-[14px] bg-white shadow-[0_12px_24px_rgba(0,0,0,0.14)] ring-1 ring-black/5
                   focus:outline-none focus:ring-2 focus:ring-blue-mrperu/60 sm:rounded-[18px] sm:shadow-[0_14px_34px_rgba(0,0,0,0.16)] lg:shadow-[0_18px_50px_rgba(0,0,0,0.20)]"
            data-video-src={t.src}
            data-video-poster={t.poster}
            aria-label={`Ver ${t.label}`}
          >
            {/* thumbnail como imagen */}
            <img
              src={t.poster}
              alt={t.label}
              class="block w-full aspect-video object-cover"
              loading="lazy"
              decoding="async"
            />

            {/* overlay play */}
            <span class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition"></span>
            <span class="absolute left-2 bottom-2 inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2 py-1 text-[10px] font-extrabold text-[#0B5871] shadow sm:left-3 sm:bottom-3 sm:gap-2 sm:px-3 sm:text-xs">
              ▶ Ver
            </span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const mainVideo = document.getElementById("casos-main-video");
  const mainSource = document.getElementById("casos-main-source");
  if (mainVideo && mainSource) {
    const buttons = document.querySelectorAll("[data-video-src][data-video-poster]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.getAttribute("data-video-src");
        const poster = btn.getAttribute("data-video-poster");
        if (!src) return;

        // Pausa y cambia
        mainVideo.pause();
        mainVideo.setAttribute("poster", poster || "");
        mainSource.setAttribute("src", src);
        mainVideo.load();
        // opcional: autoplay al cambiar
        // mainVideo.play().catch(() => {});
      });
    });
  }
</script>