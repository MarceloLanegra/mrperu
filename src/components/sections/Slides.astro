---
import { Image } from "astro:assets";

import bgSlide1Lg from "../../assets/slides/bg-banner.jpg";
import bgSlide1Xs from "../../assets/slides/slide1-xs.webp";
import bgSlide2Lg from "../../assets/slides/bg-banner2.jpg";
import bgSlide2Xs from "../../assets/slides/slide2-xs.webp";
import bgSlide3Lg from "../../assets/slides/bg-banner3.jpg";
import bgSlide3Xs from "../../assets/slides/slide3-xs.webp";

const slides = [
  {
    id: "slide-1",
    href: "#contacto",
    desktop: bgSlide1Lg,
    mobile: bgSlide1Xs,
    alt: "Slide 1 MR Perú",
  },
  {
    id: "slide-2",
    href: "https://wa.me/51997580486",
    desktop: bgSlide2Lg,
    mobile: bgSlide2Xs,
    alt: "Slide 2 MR Perú",
  },
  {
    id: "slide-3",
    href: "#video-smartlink",
    desktop: bgSlide3Lg,
    mobile: bgSlide3Xs,
    alt: "Slide 3 MR Perú",
  },
];
---

<section class="slides-section relative w-full overflow-hidden bg-white" aria-label="Slider principal">
  <div class="slides-shell relative w-full">
    <div class="slides-track" data-slides-track aria-live="polite">
      {slides.map((slide, index) => (
        <a
          href={slide.href}
          class:list={[
            "slide-item",
            index === 0 && "is-active",
            index === 0 && "is-current",
          ]}
          data-slide={index}
          aria-label={`Ir al slide ${index + 1}`}
          aria-hidden={index === 0 ? "false" : "true"}
          target={slide.href.startsWith("http") ? "_blank" : undefined}
          rel={slide.href.startsWith("http") ? "noopener noreferrer" : undefined}
        >
          <Image
            src={slide.desktop}
            alt={slide.alt}
            class="slide-media slide-media-desktop"
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
            sizes="100vw"
          />
          <Image
            src={slide.mobile}
            alt={slide.alt}
            class="slide-media slide-media-mobile"
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
            sizes="100vw"
          />
        </a>
      ))}
    </div>

    <button
      type="button"
      class="slides-arrow slides-arrow-left"
      data-slides-prev
      aria-label="Slide anterior"
    >
      <span aria-hidden="true">‹</span>
    </button>

    <button
      type="button"
      class="slides-arrow slides-arrow-right"
      data-slides-next
      aria-label="Slide siguiente"
    >
      <span aria-hidden="true">›</span>
    </button>

    <!-- <div class="slides-dots" aria-label="Indicadores del slider">
      {slides.map((_, index) => (
        <button
          type="button"
          class:list={["slides-dot", index === 0 && "is-active"]}
          data-slides-dot={index}
          aria-label={`Mostrar slide ${index + 1}`}
        ></button>
      ))}
    </div> -->
  </div>
</section>

<script is:inline>
  const sections = document.querySelectorAll('.slides-section');

  sections.forEach((section) => {
    const slides = Array.from(section.querySelectorAll('[data-slide]'));
    const dots = Array.from(section.querySelectorAll('[data-slides-dot]'));
    const prevButton = section.querySelector('[data-slides-prev]');
    const nextButton = section.querySelector('[data-slides-next]');

    if (!slides.length) return;

    let activeIndex = 0;
    let intervalId;
    let isAnimating = false;

    const track = section.querySelector('[data-slides-track]');

    const getActiveMedia = () => {
      const activeSlide = slides[activeIndex];
      if (!activeSlide) return null;

      const isMobile = window.matchMedia('(max-width: 767px)').matches;
      return activeSlide.querySelector(
        isMobile ? '.slide-media-mobile' : '.slide-media-desktop'
      );
    };

    const updateTrackHeight = () => {
      if (!track) return;

      const activeMedia = getActiveMedia();
      if (!activeMedia) return;

      const applyHeight = () => {
        const mediaHeight = activeMedia.getBoundingClientRect().height;
        if (mediaHeight > 0) {
          track.style.height = `${Math.ceil(mediaHeight)}px`;
        }
      };

      if (activeMedia.complete) {
        applyHeight();
      } else {
        activeMedia.addEventListener('load', applyHeight, { once: true });
      }
    };

    const updateDots = () => {
      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === activeIndex);
      });
    };

    const setA11yState = () => {
      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;
        slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        slide.tabIndex = isActive ? 0 : -1;
      });
    };

    const finishAnimation = (incomingSlide, outgoingSlide) => {
      outgoingSlide.classList.remove(
        'is-current',
        'is-active',
        'is-exiting-left',
        'is-exiting-right'
      );

      incomingSlide.classList.remove('is-entering-left', 'is-entering-right');
      incomingSlide.classList.add('is-active', 'is-current');

      isAnimating = false;
      updateDots();
      setA11yState();
      updateTrackHeight();
    };

    const animateTo = (nextIndex, direction) => {
      if (isAnimating || nextIndex === activeIndex) return;

      const outgoingSlide = slides[activeIndex];
      const incomingSlide = slides[nextIndex];

      isAnimating = true;
      activeIndex = nextIndex;

      slides.forEach((slide) => {
        slide.classList.remove(
          'is-entering-left',
          'is-entering-right',
          'is-exiting-left',
          'is-exiting-right'
        );
      });

      incomingSlide.classList.add('is-active');
      incomingSlide.classList.add(
        direction === 'next' ? 'is-entering-right' : 'is-entering-left'
      );
      outgoingSlide.classList.add(
        direction === 'next' ? 'is-exiting-left' : 'is-exiting-right'
      );

      requestAnimationFrame(() => {
        incomingSlide.classList.add('is-current');
        incomingSlide.classList.remove('is-entering-left', 'is-entering-right');
      });

      window.setTimeout(() => {
        finishAnimation(incomingSlide, outgoingSlide);
      }, 520);
    };

    const stopAutoplay = () => {
      window.clearInterval(intervalId);
    };

    const startAutoplay = () => {
      stopAutoplay();
      intervalId = window.setInterval(() => {
        const nextIndex = (activeIndex + 1) % slides.length;
        animateTo(nextIndex, 'next');
      }, 5000);
    };

    const goTo = (index) => {
      if (index === activeIndex) return;
      const direction = index > activeIndex ? 'next' : 'prev';
      animateTo(index, direction);
      startAutoplay();
    };

    const goPrev = (event) => {
      event?.preventDefault();
      event?.stopPropagation();
      const nextIndex = (activeIndex - 1 + slides.length) % slides.length;
      animateTo(nextIndex, 'prev');
      startAutoplay();
    };

    const goNext = (event) => {
      event?.preventDefault();
      event?.stopPropagation();
      const nextIndex = (activeIndex + 1) % slides.length;
      animateTo(nextIndex, 'next');
      startAutoplay();
    };

    prevButton?.addEventListener('click', goPrev);
    nextButton?.addEventListener('click', goNext);
    prevButton?.addEventListener('pointerup', goPrev);
    nextButton?.addEventListener('pointerup', goNext);

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goTo(index));
    });

    section.addEventListener('mouseenter', stopAutoplay);
    section.addEventListener('mouseleave', startAutoplay);
    section.addEventListener('focusin', stopAutoplay);
    section.addEventListener('focusout', startAutoplay);

    const handleResize = () => {
      updateTrackHeight();
    };

    updateDots();
    setA11yState();
    updateTrackHeight();
    startAutoplay();

    window.addEventListener('resize', handleResize);
    window.addEventListener('load', handleResize, { once: true });
  });
</script>

<style>
  .slides-section{
    position: relative;
  }

  .slides-shell{
    position: relative;
    width: 100%;
    isolation: isolate;
  }

  .slides-track{
    position: relative;
    width: 100%;
    overflow: hidden;
    height: auto;
    transition: height .45s ease;
  }

  .slide-item{
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: auto;
    opacity: 0;
    pointer-events: none;
    transform: translate3d(0, 0, 0);
    transition:
      opacity .5s ease,
      transform .5s cubic-bezier(.22,.61,.36,1);
    will-change: transform, opacity;
  }

  .slide-item.is-active{
    opacity: 1;
    z-index: 1;
  }

  .slide-item.is-current{
    pointer-events: auto;
    z-index: 2;
  }

  .slide-item.is-entering-right,
  .slide-item.is-exiting-left{
    transform: translate3d(0, 0, 0);
  }

  .slide-item.is-entering-right{
    opacity: 1;
    transform: translate3d(6%, 0, 0);
  }

  .slide-item.is-exiting-left{
    opacity: 0;
    transform: translate3d(-4%, 0, 0);
  }

  .slide-item.is-entering-left,
  .slide-item.is-exiting-right{
    transform: translate3d(0, 0, 0);
  }

  .slide-item.is-entering-left{
    opacity: 1;
    transform: translate3d(-6%, 0, 0);
  }

  .slide-item.is-exiting-right{
    opacity: 0;
    transform: translate3d(4%, 0, 0);
  }

  .slide-media{
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
  }

  .slide-media-desktop{
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .slide-media-mobile{
    display: none;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .slides-arrow{
    position: absolute;
    top: 50%;
    z-index: 20;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    padding: 0;
    border: 0;
    background: transparent;
    color: #f5b400;
    cursor: pointer;
    transform: translateY(-50%);
    transition: transform .25s ease, color .25s ease, opacity .25s ease;
    opacity: .95;
    pointer-events: auto;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .slides-arrow:hover{
    transform: translateY(-50%) scale(1.12);
    color: #ffd24d;
    opacity: 1;
  }

  .slides-arrow > span{
    display: block;
    font-size: 64px;
    font-weight: 700;
    line-height: .8;
    text-shadow: 0 6px 18px rgba(0,0,0,.28);
    transform: translateY(-2px);
  }

  .slides-arrow-left{
    left: 12px;
  }

  .slides-arrow-left > span{
    transform: translate(-1px, -1px);
  }

  .slides-arrow-right{
    right: 12px;
  }

  .slides-arrow-right > span{
    transform: translate(1px, -1px);
  }

  .slides-arrow::before{
    content: "";
    position: absolute;
    inset: -10px;
  }

  .slides-dots{
    position: absolute;
    left: 50%;
    bottom: 14px;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 10px;
    transform: translateX(-50%);
  }

  .slides-dot{
    width: 10px;
    height: 10px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,.55);
    box-shadow: 0 4px 10px rgba(0,0,0,.12);
    cursor: pointer;
    transition: transform .25s ease, background .25s ease;
  }

  .slides-dot.is-active{
    background: #ffffff;
    transform: scale(1.22);
  }

  @media (max-width: 767px){
    .slides-track{
      height: auto;
      min-height: 0;
      transition: height .45s ease;
    }

    .slide-media-desktop{
      display: none;
    }

    .slide-media-mobile{
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .slides-arrow{
      width: 52px;
      height: 52px;
    }

    .slides-arrow > span{
      font-size: 52px;
    }

    .slides-arrow-left{
      left: 4px;
    }

    .slides-arrow-right{
      right: 4px;
    }

    .slide-item.is-entering-right{
      transform: translate3d(3.5%, 0, 0);
    }

    .slide-item.is-exiting-left{
      transform: translate3d(-2.5%, 0, 0);
    }

    .slide-item.is-entering-left{
      transform: translate3d(-3.5%, 0, 0);
    }

    .slide-item.is-exiting-right{
      transform: translate3d(2.5%, 0, 0);
    }
  }
</style>