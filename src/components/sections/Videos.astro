---
type VideoItem = {
  id: string;
  titleTop: string;
  caption: string;
  embed?: string;
  src?: string;
  isShort?: boolean;
};

const videos: VideoItem[] = [
  {
    id: "video-vsd",
    titleTop: "¿QUÉ ES UN COMPRESOR VSD?",
    embed: "https://www.youtube.com/embed/oHRtH1gK1_s?si=XVNIigWs7r-K3_GV",
    caption: "¿QUÉ ES UN COMPRESOR VSD?",
  },
  {
    id: "video-smartlink",
    titleTop: "SMARTLINK",
    embed: "https://www.youtube.com/embed/j_84yQlYrtM",
    isShort: true,
    caption: "¿Te imaginas monitorear tus compresores desde tu teléfono?",
  },
];
---

<section id="videos" class="bg-white py-8 sm:py-12 lg:py-14">
  <div class="mx-auto w-[min(1400px,calc(100%-20px))] space-y-8 sm:w-[min(1400px,calc(100%-24px))] sm:space-y-12 lg:space-y-14">
    {videos.map((v) => (
      <div class="relative rounded-[22px] border-2 border-blue-mrperu  px-3 pb-6 pt-12 sm:rounded-[28px] sm:px-6 sm:pb-8 sm:pt-14 lg:px-8 lg:pb-10 lg:pt-16">
        {/* pill superior */}
        <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-24px)] max-w-max -translate-x-1/2 -translate-y-1/2 sm:w-auto">
          <div
            class="rounded-[12px] bg-white px-4 py-2 text-center
                   shadow-[0_10px_25px_rgba(0,0,0,0.20)] ring-1 ring-black/5 sm:rounded-[14px] sm:px-6 sm:py-3"
          >
            <span class="text-blue-mrperu block text-balance font-extrabold tracking-wide text-[14px] leading-tight sm:text-[18px] lg:text-[22px]">
              {v.titleTop}
            </span>
          </div>
        </div>

        {/* card del video */}
        <div class:list={[
          "mx-auto w-full",
          v.isShort ? "max-w-[280px] sm:max-w-[360px] lg:max-w-[420px]" : "max-w-full lg:max-w-[860px]",
        ]}>
          <div class="overflow-hidden rounded-[18px] bg-white shadow-[0_18px_40px_rgba(0,0,0,0.22)] ring-1 ring-black/5 sm:rounded-[22px] sm:shadow-[0_22px_60px_rgba(0,0,0,0.35)]">
            <div class="bg-white">
              {v.embed ? (
                <iframe
                  class:list={[
                    "block bg-black w-full mx-auto",
                    v.isShort ? "aspect-[9/16]" : "aspect-video",
                  ]}
                  src={v.embed}
                  title={v.caption}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                />
              ) : (
                <video
                  class:list={[
                    "block bg-black w-full mx-auto",
                    v.isShort ? "aspect-[9/16]" : "aspect-video",
                  ]}
                  controls
                  playsinline
                  preload="metadata"
                >
                  {v.src && <source src={v.src} type="video/mp4" />}
                  Tu navegador no soporta videos HTML5.
                </video>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>