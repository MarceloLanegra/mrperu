---
/**
 * Pon tus videos en /public/videos/
 * Ej: /public/videos/que-es-compresor-vsd.mp4
 *     /public/videos/smartlink.mp4
 *
 * Si aún no tienes mp4, igual funciona con el layout (solo cambia src).
 */
 const videos = [
  {
    id: "video-vsd",
    titleTop: "QUÉ ES UN COMPRESOR VSD",
    src: "/videos/que-es-compresor-vsd.mp4",
    poster: "/videos/poster-vsd.jpg", // opcional
    caption: "¿QUÉ ES UN COMPRESOR VSD?",
  },
  {
    id: "video-smartlink",
    titleTop: "SMARTLINK",
    src: "/videos/smartlink.mp4",
    poster: "/videos/poster-smartlink.jpg", // opcional
    caption: "¿Te imaginas monitorear tus compresores desde tu teléfono?",
  },
];
---

<section id="videos" class="bg-white py-10 sm:py-14">
  <div class="mx-auto w-[min(1400px,calc(100%-24px))] space-y-10 sm:space-y-14">
    {videos.map((v) => (
      <div class="relative rounded-[28px] border-2 border-[#0197C5] bg-[#F2F2F2] px-4 pb-10 pt-14 sm:px-8 sm:pt-16">
        {/* pill superior */}
        <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2">
          <div
            class="rounded-[14px] bg-white px-6 py-3 text-center
                   shadow-[0_10px_25px_rgba(0,0,0,0.20)] ring-1 ring-black/5"
          >
            <span class="text-[#0197C5] font-extrabold tracking-wide text-[18px] sm:text-[22px]">
              {v.titleTop}
            </span>
          </div>
        </div>

        {/* card del video */}
        <div class="mx-auto w-full max-w-[860px]">
          <div class="overflow-hidden rounded-[22px] bg-white shadow-[0_22px_60px_rgba(0,0,0,0.35)] ring-1 ring-black/5">
            <div class="bg-white">
              <video
                class="block w-full aspect-video bg-black"
                controls
                playsinline
                preload="metadata"
                poster={v.poster}
              >
                <source src={v.src} type="video/mp4" />
                Tu navegador no soporta videos HTML5.
              </video>
            </div>


          </div>
        </div>
      </div>
    ))}
  </div>
</section>