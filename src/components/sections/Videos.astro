---
type VideoItem = {
  id: string;
  titleTop: string;
  caption: string;
  embed?: string;
  src?: string;
  isShort?: boolean;
};

const videos: VideoItem[] = [
  {
    id: "video-vsd",
    titleTop: "¿QUÉ ES UN COMPRESOR VSD?",
    embed: "https://www.youtube.com/embed/oHRtH1gK1_s?si=XVNIigWs7r-K3_GV",
    caption: "¿QUÉ ES UN COMPRESOR VSD?",
  },
  {
    id: "video-smartlink",
    titleTop: "SMARTLINK: TECNOLOGÍA INTELIGENTE PARA MONITOREO",
    embed: "https://www.youtube.com/embed/j_84yQlYrtM",
    isShort: true,
    caption: "¿Te imaginas monitorear tus compresores desde tu teléfono?",
  },
];
---

<section id="videos" class="videos-reveal-section bg-white py-10 sm:py-12 lg:py-14">
  <div class="mx-auto w-[min(1400px,calc(100%-20px))] space-y-14 sm:w-[min(1400px,calc(100%-24px))] sm:space-y-12 lg:space-y-14">
    {videos.map((v) => (
      <div id={v.id} class="videos-reveal relative rounded-[24px] border-2 border-blue-mrperu px-4 pb-8 pt-18 sm:rounded-[28px] sm:px-6 sm:pb-8 sm:pt-20 lg:px-8 lg:pb-10 lg:pt-24 scroll-mt-24">
        {/* pill superior */}
        <div class="absolute left-1/2 top-0 z-10 w-[calc(100%-16px)] sm:w-auto sm:min-w-[520px] lg:min-w-[420px] -translate-x-1/2 -translate-y-1/2 mb-2">
          <div
            class="rounded-[12px] bg-white px-4 py-2 text-center shadow-[0_10px_25px_rgba(0,0,0,0.20)] ring-1 ring-black/5 sm:rounded-[14px] sm:px-8 sm:py-3"
          >
            <span class="text-blue-mrperu block text-center text-balance font-extrabold tracking-wide text-[23px] leading-tight sm:text-[18px] lg:text-[26px]">
              {v.titleTop}
            </span>
          </div>
        </div>

        {/* card del video */}
        <div class:list={[
          "mx-auto w-full",
          v.isShort ? "max-w-[300px] sm:max-w-[360px] lg:max-w-[420px]" : "max-w-full lg:max-w-[860px]",
        ]}>
          <div class="overflow-hidden rounded-[20px] bg-white shadow-[0_18px_40px_rgba(0,0,0,0.22)] ring-1 ring-black/5 sm:rounded-[22px] sm:shadow-[0_22px_60px_rgba(0,0,0,0.35)]">
            <div class="bg-white">
              {v.embed ? (
                <iframe
                  class:list={[
                    "block bg-black w-full mx-auto",
                    v.isShort ? "aspect-[9/16]" : "aspect-video",
                  ]}
                  src={v.embed}
                  title={v.caption}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                />
              ) : (
                <video
                  class:list={[
                    "block bg-black w-full mx-auto",
                    v.isShort ? "aspect-[9/16]" : "aspect-video",
                  ]}
                  controls
                  playsinline
                  preload="metadata"
                >
                  {v.src && <source src={v.src} type="video/mp4" />}
                  Tu navegador no soporta videos HTML5.
                </video>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const section = document.querySelector('.videos-reveal-section');
    if (!section) return;

    const items = Array.from(section.querySelectorAll('.videos-reveal'));
    if (!items.length) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion) {
      items.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.16,
        rootMargin: '0px 0px -8% 0px',
      }
    );

    items.forEach((item, index) => {
      item.style.setProperty('--reveal-delay', `${index * 120}ms`);
      observer.observe(item);
    });
  })();
</script>

<style>
  .videos-reveal{
    opacity: 0;
    transform: translate3d(0, 28px, 0) scale(.985);
    transition:
      opacity .75s ease,
      transform .75s cubic-bezier(.22,.61,.36,1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .videos-reveal.is-visible{
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (prefers-reduced-motion: reduce){
    .videos-reveal{
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>