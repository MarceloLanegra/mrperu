---
import Input from "../Input.astro";
import Wrapper from "../Wrapper.astro";
import { RECAPTCHA_SITE_KEY } from "astro:env/client";
---

<section
  id="contacto"
  class="form-reveal-section relative isolate overflow-hidden bg-[url('../assets/bg-form-xs.webp')] bg-cover bg-center bg-no-repeat py-14 sm:bg-[url('../assets/bg-form.webp')] sm:py-16 lg:py-24 scroll-mt-24"
>
  <div class="absolute inset-0 bg-black/45"></div>
  <div class="absolute inset-0 bg-linear-to-r from-black/55 via-black/25 to-black/20"></div>

  <Wrapper>
    <div class="relative z-10 flex justify-center sm:justify-start">
      <div class="form-reveal form-reveal-card w-full max-w-88 rounded-[28px] border border-white/15 bg-white/10 px-5 py-6 shadow-[0_18px_60px_rgba(0,0,0,0.30)] backdrop-blur-[10px] sm:max-w-136 sm:px-8 sm:py-8 lg:max-w-xl lg:px-10 lg:py-10">
        <span class="form-reveal form-reveal-badge inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-white/85 sm:text-xs">
          Diagnóstico gratuito
        </span>

        <h4 class="form-reveal form-reveal-title mt-4 max-w-none text-pretty text-[1.8rem] font-bold leading-[1.05] text-white sm:text-[2.35rem] lg:text-[2.8rem]">
          Obtén un diagnóstico gratuito para conocer tu consumo energético.
        </h4>

        <p class="form-reveal form-reveal-copy mt-3 max-w-120 text-sm leading-6 text-white/80 sm:text-[0.98rem]">
          Completa tus datos y nuestro equipo te contactará para evaluar tu consumo y proponerte una solución más eficiente.
        </p>

        <form id="contact-form" class="form-reveal form-reveal-form mt-8 sm:mt-7">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-4">
            <div class="sm:col-span-2">
              <Input
                required
                name="fullName"
                placeholder="Nombre y apellido"
              />
              <span id="fullName-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
            <div class="sm:col-span-2">
              <Input
                required
                name="company"
                placeholder="Empresa"
              />
              <span id="company-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
            <div>
              <Input
                required
                name="email"
                placeholder="Email corporativo"
                type="email"
              />
              <span id="email-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
            <div>
              <Input
                required
                name="phone"
                placeholder="Teléfono"
                type="tel"
              />
              <span id="phone-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
          </div>
          <span id="form-message" class="hidden mt-4 text-sm text-center"></span>
          <div class="mt-7 flex flex-col gap-3 sm:mt-8 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xs leading-5 text-white/70 sm:max-w-[16rem]">
              Al enviar este formulario, aceptas ser contactado por nuestro equipo comercial.
            </p>

            <button
              id="submit-button"
              type="submit"
              class="inline-flex min-h-13 cursor-pointer items-center justify-center rounded-full bg-yellow-mrperu px-8 py-3 text-[1rem] font-semibold text-white shadow-[inset_0_4.41px_12.12px_rgba(0,0,0,0.22),0_10px_28px_rgba(0,0,0,0.18)] transition-all duration-300 hover:-translate-y-1 hover:scale-[1.01] hover:bg-yellow-mrperu/90 hover:shadow-[inset_0_4.41px_12.12px_rgba(0,0,0,0.22),0_16px_34px_rgba(0,0,0,0.24)] active:translate-y-0 active:scale-[0.995] disabled:opacity-75 disabled:cursor-not-allowed"
            >
            Solicitar Diagnóstico
            </button>
          </div>
        </form>
      </div>
    </div>
  </Wrapper>
</section>

<script is:inline src={`https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`}></script>

<script is:inline>
  (() => {
    const section = document.querySelector('.form-reveal-section');
    if (!section) return;

    const items = Array.from(section.querySelectorAll('.form-reveal'));
    if (!items.length) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion) {
      items.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.16,
        rootMargin: '0px 0px -8% 0px',
      }
    );

    items.forEach((item, index) => {
      item.style.setProperty('--reveal-delay', `${index * 110}ms`);
      observer.observe(item);
    });
  })();
</script>

<script>
  import { isInputError } from "astro:actions"
  import { actions } from "astro:actions"
  import { RECAPTCHA_SITE_KEY } from "astro:env/client"

  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-button') as HTMLButtonElement
  const messageResponse = document.getElementById('form-message') as HTMLSpanElement
  const fullNameError = document.getElementById('fullName-error') as HTMLSpanElement
  const companyError = document.getElementById('company-error') as HTMLSpanElement
  const emailError = document.getElementById('email-error') as HTMLSpanElement
  const phoneError = document.getElementById('phone-error') as HTMLSpanElement

  const clearErrors = () => {
    messageResponse.classList.add('hidden')
    messageResponse.classList.remove('block','text-red-500', 'text-green-500')
    fullNameError.classList.add('hidden')
    fullNameError.classList.remove('block', 'text-red-500')
    companyError.classList.add('hidden')
    companyError.classList.remove('block', 'text-red-500')
    emailError.classList.add('hidden')
    emailError.classList.remove('block', 'text-red-500')
    phoneError.classList.add('hidden')
    phoneError.classList.remove('block', 'text-red-500')
  }

  clearErrors()

  const handleSubmit = async (e: Event) => {
    e.preventDefault()
    clearErrors()
    const form = e.target as HTMLFormElement
    const formData = new FormData(form)

    submitBtn.disabled = true

    const submitFormWithRecaptcha = async (token: string) => {
      formData.append('recaptcha', token)

      const { data, error } = await actions.sendContactEmail(formData)
      
      submitBtn.disabled = false

      if (data) {
        form.reset()
        messageResponse.textContent = data.message
        messageResponse.classList.remove('hidden')
        messageResponse.classList.add('block', 'text-green-500')
      } 

      if (isInputError(error)) {
        if (error.fields.fullName) {
          const message = error.fields.fullName.join(', ')
          fullNameError.textContent = message
          fullNameError.classList.remove('hidden')
          fullNameError.classList.add('block', 'text-red-500')
        }
        if (error.fields.company) {
          const message = error.fields.company.join(', ')
          companyError.textContent = message
          companyError.classList.remove('hidden')
          companyError.classList.add('block', 'text-red-500')
        }
        if (error.fields.email) {
          const message = error.fields.email.join(', ')
          emailError.textContent = message
          emailError.classList.remove('hidden')
          emailError.classList.add('block', 'text-red-500')
        }
        if (error.fields.phone) {
          const message = error.fields.phone.join(', ')
          phoneError.textContent = message
          phoneError.classList.remove('hidden')
          phoneError.classList.add('block', 'text-red-500')
        }
      } else if (error) {
        messageResponse.textContent = error.message
        messageResponse.classList.remove('hidden')
        messageResponse.classList.add('block', 'text-red-500')
      }
    }

    if (typeof grecaptcha === 'undefined') {
      submitBtn.disabled = false
      messageResponse.textContent = 'Error: reCAPTCHA aún no ha cargado. Inténtalo en un momento.'
      messageResponse.classList.remove('hidden')
      messageResponse.classList.add('block', 'text-red-500')
      return
    }

    grecaptcha.ready(function() {
      grecaptcha.execute(RECAPTCHA_SITE_KEY, {action: 'submit'}).then(function(token: string) {
        submitFormWithRecaptcha(token)
      }).catch(function(err: any) {
        submitBtn.disabled = false
        messageResponse.textContent = 'Error de conexión con reCAPTCHA. Inténtalo de nuevo.'
        messageResponse.classList.remove('hidden')
        messageResponse.classList.add('block', 'text-red-500')
      })
    })
  }

  if (form && form instanceof HTMLFormElement) {
    form.addEventListener('submit', (e) => handleSubmit(e))
  }
</script>

<style>
  .form-reveal{
    opacity: 0;
    transform: translate3d(0, 28px, 0) scale(.985);
    transition:
      opacity .75s ease,
      transform .75s cubic-bezier(.22,.61,.36,1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .form-reveal-card{
    transform: translate3d(0, 30px, 0) scale(.985);
  }

  .form-reveal-badge{
    transform: translate3d(0, 14px, 0) scale(.99);
  }

  .form-reveal-title{
    transform: translate3d(0, 18px, 0) scale(.995);
  }

  .form-reveal-copy{
    transform: translate3d(0, 22px, 0) scale(.995);
  }

  .form-reveal-form{
    transform: translate3d(0, 26px, 0) scale(.99);
  }

  .form-reveal.is-visible{
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (prefers-reduced-motion: reduce){
    .form-reveal{
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>