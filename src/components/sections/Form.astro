---
import { actions } from "astro:actions";
import Input from "../Input.astro";
import Wrapper from "../Wrapper.astro";
---

<section
  id="contacto"
  class="relative isolate overflow-hidden bg-[url('../assets/bg-form-xs.webp')] bg-cover bg-center bg-no-repeat py-14 sm:bg-[url('../assets/bg-form.webp')] sm:py-16 lg:py-24  scroll-mt-24"
>
  <div class="absolute inset-0 bg-black/45"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-black/25 to-black/20"></div>

  <Wrapper>
    <div class="relative z-10 flex justify-center sm:justify-start">
      <div class="w-full max-w-88 rounded-[28px] border border-white/15 bg-white/10 px-5 py-6 shadow-[0_18px_60px_rgba(0,0,0,0.30)] backdrop-blur-[10px] sm:max-w-136 sm:px-8 sm:py-8 lg:max-w-xl lg:px-10 lg:py-10">
        <span class="inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-white/85 sm:text-xs">
          Diagnóstico gratuito
        </span>

        <h4 class="mt-4 max-w-none text-pretty text-[1.8rem] font-bold leading-[1.05] text-white sm:text-[2.35rem] lg:text-[2.8rem]">
          Obtén un diagnóstico gratuito para conocer tu consumo energético.
        </h4>

        <p class="mt-3 max-w-120 text-sm leading-6 text-white/80 sm:text-[0.98rem]">
          Completa tus datos y nuestro equipo te contactará para evaluar tu consumo y proponerte una solución más eficiente.
        </p>

        <form method="post" id="contact-form" action={actions.sendContactEmail} class="mt-8 sm:mt-7">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-4">
            <div class="sm:col-span-2">
              <Input
                required
                name="fullName"
                placeholder="Nombre y apellido"
              />
              <span id="fullName-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
            <div class="sm:col-span-2">
              <Input
                required
                name="company"
                placeholder="Empresa"
              />
              <span id="company-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
            <div>
              <Input
                required
                name="email"
                placeholder="Email corporativo"
                type="email"
              />
              <span id="email-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
            <div>
              <Input
                required
                name="phone"
                placeholder="Teléfono"
                type="tel"
              />
              <span id="phone-error" class="hidden mt-2 ml-4 text-sm"></span>
            </div>
          </div>
          <span id="form-message" class="hidden mt-4 text-sm text-center"></span>
          <div class="mt-7 flex flex-col gap-3 sm:mt-8 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xs leading-5 text-white/70 sm:max-w-[16rem]">
              Al enviar este formulario, aceptas ser contactado por nuestro equipo comercial.
            </p>

            <button
              type="submit"
              class="inline-flex min-h-13 items-center justify-center rounded-full bg-yellow-mrperu px-8 py-3 text-[1rem] font-semibold text-white shadow-[inset_0_4.41px_12.12px_rgba(0,0,0,0.22),0_10px_28px_rgba(0,0,0,0.18)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-yellow-mrperu/90 active:translate-y-0"
            >
              Enviar
            </button>
          </div>
        </form>
      </div>
    </div>
  </Wrapper>
</section>

<script>
  import { isInputError } from "astro:actions"
  import { actions } from "astro:actions"

  const form = document.getElementById('contact-form') as HTMLFormElement
  const messageResponse = document.getElementById('form-message') as HTMLSpanElement
  const fullNameError = document.getElementById('fullName-error') as HTMLSpanElement
  const companyError = document.getElementById('company-error') as HTMLSpanElement
  const emailError = document.getElementById('email-error') as HTMLSpanElement
  const phoneError = document.getElementById('phone-error') as HTMLSpanElement

  const clearErrors = () => {
    messageResponse.classList.add('hidden')
    messageResponse.classList.remove('block','text-red-500', 'text-green-500')
    fullNameError.classList.add('hidden')
    fullNameError.classList.remove('block', 'text-red-500')
    companyError.classList.add('hidden')
    companyError.classList.remove('block', 'text-red-500')
    emailError.classList.add('hidden')
    emailError.classList.remove('block', 'text-red-500')
    phoneError.classList.add('hidden')
    phoneError.classList.remove('block', 'text-red-500')
  }

  clearErrors()

  const handleSubmit = async (e: Event) => {
    e.preventDefault()
    clearErrors()
    const form = e.target as HTMLFormElement
    const formData = new FormData(form)

    const { data, error } = await actions.sendContactEmail(formData)
    
    if (data) {
      form.reset()
      messageResponse.textContent = data.message
      messageResponse.classList.remove('hidden')
      messageResponse.classList.add('block', 'text-green-500')
    } 

    if (isInputError(error)) {
      if (error.fields.fullName) {
        const message = error.fields.fullName.join(', ')
        fullNameError.textContent = message
        fullNameError.classList.remove('hidden')
        fullNameError.classList.add('block', 'text-red-500')
      }
      if (error.fields.company) {
        const message = error.fields.company.join(', ')
        companyError.textContent = message
        companyError.classList.remove('hidden')
        companyError.classList.add('block', 'text-red-500')
      }
      if (error.fields.email) {
        const message = error.fields.email.join(', ')
        emailError.textContent = message
        emailError.classList.remove('hidden')
        emailError.classList.add('block', 'text-red-500')
      }
      if (error.fields.phone) {
        const message = error.fields.phone.join(', ')
        phoneError.textContent = message
        phoneError.classList.remove('hidden')
        phoneError.classList.add('block', 'text-red-500')
      }
    }
  }

  if (form && form instanceof HTMLFormElement) {
    form.addEventListener('submit', (e) => handleSubmit(e))
  }
</script>