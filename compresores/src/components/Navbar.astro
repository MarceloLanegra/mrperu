---
import { Image } from "astro:assets";
import logo from "../assets/logo/mrperu-logo-web.png";

const links = [
  { label: "Beneficios", href: "#beneficios" },
  { label: "Clientes", href: "#clientes" },
  { label: "Casos de éxito", href: "#casos-de-exito" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="sticky top-0 left-0 right-0 z-50">
  <nav class="mx-auto w-[min(1100px,calc(100%-24px))] font-sans">
    <div
      class="flex items-center justify-between px-6 py-4
             bg-white shadow-[0_6px_18px_rgba(0,0,0,0.12)]"
    >
      <!-- Logo izquierdo -->
      <a href="#inicio" class="flex items-center gap-3">
        <Image
          src={logo}
          alt="MR Perú"
          class="w-[81px] h-[81px] object-contain"
          loading="eager"
          decoding="async"
        />
      </a>

   
      <ul class="hidden md:flex items-center gap-8">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class={
                "transition text-[15px] font-semibold tracking-tight " +
                (l.label === "Beneficios"
                  ? "text-[#FBBE2E]"
                  : "text-[#0197C5] hover:text-[#FBBE2E]")
              }
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

     
      <div class="flex items-center gap-3">

        <a
          href="#contacto"
          class="hidden sm:inline-flex items-center justify-center rounded-xl px-5 py-2 text-[15px] font-semibold
                 text-white transition
                 bg-[#FBBE2E] hover:bg-[#F7B400]
                 shadow-[0_6px_14px_rgba(0,0,0,0.18)]
                 shadow-[inset_0_4.41px_12.12px_rgba(0,0,0,0.38),0_6px_14px_rgba(0,0,0,0.18)]"
        >
          ¡Solicita diagnóstico gratis!
        </a>

        <!-- Mobile menu -->
        <details class="relative md:hidden">
          <summary
            class="list-none inline-flex items-center justify-center rounded-xl p-2
                   bg-slate-100 text-slate-800 hover:bg-slate-200 transition cursor-pointer"
            aria-label="Abrir menú"
          >
            <!-- Hamburger icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </summary>

          <div
            class="absolute right-0 mt-3 w-60 overflow-hidden rounded-2xl
                   bg-white ring-1 ring-black/5 shadow-[0_12px_30px_rgba(0,0,0,0.16)]"
          >
            <div class="p-2">
              {links.map((l) => (
                <a
                  href={l.href}
                  class="block rounded-xl px-3 py-2 text-sm font-semibold text-[#0197C5] hover:bg-slate-50 hover:text-[#017AA3] transition"
                >
                  {l.label}
                </a>
              ))}

              <a
                href="#contacto"
                class="mt-2 block rounded-xl px-3 py-2 text-sm font-semibold text-white text-center transition
                       bg-[#FBBE2E] hover:bg-[#F7B400]
                       shadow-[inset_0_4.41px_12.12px_rgba(0,0,0,0.38),0_6px_14px_rgba(0,0,0,0.18)]"
              >
                ¡Solicita diagnóstico gratis!
              </a>
            </div>
          </div>
        </details>
      </div>
    </div>
  </nav>
</header>